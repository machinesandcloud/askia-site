---
layout: layout.njk
---
{% set metaType = "article" %}
{% set metaImage = featuredImage %}
{% set metaImageAlt = imageAlt %}
<div class="resource-theme-page">
<article class="blog-post">
  <header class="blog-post-hero resource-theme-hero">
    <div class="container blog-post-hero-grid">
      <div>
      <p class="hero-eyebrow">Career Intelligence</p>
        <h1 class="blog-post-title">{{ title }}</h1>
        <p class="blog-post-subtitle">{{ description }}</p>
        <div class="blog-post-meta">
          <span>By {{ author or "Askia Team" }}</span>
          <span>{{ publishDate }}</span>
          <span>{{ readTime }}</span>
        </div>
        <div class="blog-post-tags">
          {% for category in categories %}
          <span class="category-pill">{{ category }}</span>
          {% endfor %}
        </div>
      </div>
      <div class="blog-post-image">
        <img src="{{ featuredImage }}" alt="{{ imageAlt }}" />
      </div>
    </div>
  </header>

  <section class="section blog-post-body">
    <div class="container blog-post-content">
      <div class="content-panel">
        {{ content | safe }}
      </div>
      <aside class="blog-post-sidebar">
        {% if "Interview Intelligence" in categories or "Interview" in categories %}
        <div class="sidebar-card sidebar-card-service">
          <strong>Turn prep into offers</strong>
          <p>Mock interviews, story coaching, behavioral and technical prep with a coach who has been on the hiring side.</p>
          <a class="btn btn-ghost" href="/interview-prep/">Interview Prep →</a>
        </div>
        {% elif "Salary & Compensation" in categories or "Salary" in categories %}
        <div class="sidebar-card sidebar-card-service">
          <strong>Stop leaving money on the table</strong>
          <p>Askia clients average a $47K increase in negotiated compensation. Get the coaching that makes that happen.</p>
          <a class="btn btn-ghost" href="/salary-negotiation/">Salary Negotiation →</a>
        </div>
        {% elif "LinkedIn & Resume" in categories or "Resume" in categories %}
        <div class="sidebar-card sidebar-card-service">
          <strong>Get your resume and LinkedIn working together</strong>
          <p>Resume revision + LinkedIn optimization — done-with-you, informed by hiring-side experience.</p>
          <a class="btn btn-ghost" href="/resume-writing/">Resume Writing →</a>
        </div>
        {% elif "Software Careers" in categories or "Tech Careers" in categories %}
        <div class="sidebar-card sidebar-card-service">
          <strong>Coaching built for tech professionals</strong>
          <p>From mid-level IC to Staff, EM, and beyond — Askia’s founder led engineering teams for a decade.</p>
          <a class="btn btn-ghost" href="/software-engineer-career-coaching/">Tech Career Coaching →</a>
        </div>
        {% else %}
        <div class="sidebar-card sidebar-card-service">
          <strong>Free 30-min strategy call</strong>
          <p>Map the fastest path from your current role to your target level — no pitch, just a plan.</p>
          <a class="btn btn-ghost" href="{{ site.cta.link }}">Book It Free →</a>
        </div>
        {% endif %}
        <div class="sidebar-card">
          <strong>Free resume review toolkit</strong>
          <p>The 6-point checklist coaches use to audit resumes in the first 30 seconds.</p>
          <button class="btn btn-ghost" type="button" data-open-lead-modal>Get It Free</button>
        </div>
        <div class="sidebar-card">
          <strong>Score your job readiness</strong>
          <p>48-point self-assessment — find the gaps before recruiters do.</p>
          <a class="btn btn-primary" href="/career-readiness-index/">Take the Index</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-mid-cta">
    <div class="container">
      <div class="mid-cta-band">
        <div class="mid-cta-content">
          <p class="hero-eyebrow">Free Toolkit</p>
          <h3>Get the Resume Review Toolkit — Free</h3>
          <p>The exact checklist our coaches use to diagnose what’s holding a resume back from interviews.</p>
        </div>
        <div class="mid-cta-actions">
          <button class="btn btn-primary" type="button" data-open-lead-modal>Send It to Me</button>
          <a class="btn btn-ghost" href="{{ site.cta.link }}">Book a Strategy Call</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section blog-post-cta">
    <div class="container cta-band">
      <div>
        <h2 class="section-title">Want this system applied to your exact target?</h2>
        <p class="section-subtitle">We’ll turn your experience into market signal and a clear offer plan.</p>
      </div>
      <a class="btn btn-primary" href="{{ site.cta.link }}">Book Your Strategy Call</a>
    </div>
  </section>

  <section class="section blog-related">
    <div class="container">
      <h2 class="section-title section-title-glow">Related reads</h2>
      <div class="blog-grid">
        {% set primaryCategory = "" %}
        {% if categories and categories.length %}
          {% set primaryCategory = categories[0] %}
        {% endif %}
        {% set relatedCount = 0 %}
        {% for post in collections.publicBlog | reverse %}
          {% if post.url != page.url and relatedCount < 6 %}
          {% set matchCategory = primaryCategory and (primaryCategory in post.data.categories) %}
          {% if matchCategory or not primaryCategory %}
          <article class="blog-card">
            <a class="blog-card-image" href="{{ post.url }}">
              <img src="{{ post.data.featuredImage }}" alt="{{ post.data.imageAlt }}" loading="lazy" />
            </a>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                {% for category in post.data.categories %}
                  <span class="category-pill">{{ category }}</span>
                {% endfor %}
              </div>
              <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
              <p>{{ post.data.description }}</p>
              <div class="blog-card-foot">
                <span>{{ post.data.readTime }}</span>
                <span>{{ post.data.publishDate }}</span>
              </div>
            </div>
          </article>
          {% set relatedCount = relatedCount + 1 %}
          {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
</article>

</div>

<div class="reading-cta" id="reading-cta" aria-live="polite" hidden>
  <div class="reading-cta-copy">
    <strong>Ready to apply this to your own search?</strong>
    <span>89% of Askia clients land offers within 60 days.</span>
  </div>
  <div class="reading-cta-actions">
    <button class="btn btn-ghost btn-sm" type="button" data-open-lead-modal>Get Free Toolkit</button>
    <a class="btn btn-primary btn-sm" href="{{ site.cta.link }}">Book a Call</a>
    <button class="reading-cta-dismiss" type="button" id="reading-cta-dismiss" aria-label="Dismiss">✕</button>
  </div>
</div>

<script>
  (function() {
    var cta = document.getElementById('reading-cta');
    var dismiss = document.getElementById('reading-cta-dismiss');
    if (!cta) return;
    var dismissed = sessionStorage.getItem('askia_reading_cta_dismissed');
    if (dismissed) return;
    cta.hidden = false;
    var shown = false;
    var threshold = 0.65;
    function checkScroll() {
      if (shown) return;
      var scrolled = window.scrollY + window.innerHeight;
      var total = document.documentElement.scrollHeight;
      if (scrolled / total >= threshold) {
        shown = true;
        cta.classList.add('is-visible');
        window.removeEventListener('scroll', checkScroll);
      }
    }
    window.addEventListener('scroll', checkScroll, { passive: true });
    dismiss.addEventListener('click', function() {
      cta.classList.remove('is-visible');
      sessionStorage.setItem('askia_reading_cta_dismissed', '1');
    });
  })();
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "image": {
      "@type": "ImageObject",
      "url": "{{ site.url }}{{ featuredImage }}",
      "alt": "{{ imageAlt }}"
    },
    "author": {
      "@type": "Person",
      "name": "{{ author or 'Steve Ngoumnai' }}",
      "url": "https://askia.tech/about/",
      "jobTitle": "Career Coach & Founder",
      "worksFor": {
        "@type": "Organization",
        "name": "Askia",
        "url": "https://askia.tech"
      },
      "knowsAbout": ["career coaching", "resume writing", "interview preparation", "salary negotiation", "LinkedIn optimization", "job search strategy", "tech careers", "engineering management"],
      "sameAs": ["https://www.linkedin.com/in/stevengoumnai"]
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.name }}",
      "url": "https://askia.tech",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.url }}/assets/askia-logo-512.png"
      }
    },
    "datePublished": "{{ publishDateISO }}",
    "dateModified": "{{ updatedDateISO or publishDateISO }}",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}"
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".blog-post-subtitle", "h2", ".content-panel p"]
    },
    "isPartOf": {
      "@type": "Blog",
      "name": "Askia Career Intelligence",
      "url": "https://askia.tech/blog/"
    }
  }
</script>

{% if breadcrumbs %}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {% for crumb in breadcrumbs %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ crumb.name }}",
        "item": "{{ site.url }}{{ crumb.url }}"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
</script>
{% endif %}

{% if faq %}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in faq %}
      {
        "@type": "Question",
        "name": "{{ item.q }}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{{ item.a }}"
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
</script>
{% endif %}

{% if howto %}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "{{ howto.name }}",
    "step": [
      {% for step in howto.steps %}
      {
        "@type": "HowToStep",
        "name": "{{ step.name }}",
        "text": "{{ step.text }}"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
</script>
{% endif %}
