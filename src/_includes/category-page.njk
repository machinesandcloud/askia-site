{# Category landing page — redesigned to match resource-hub.njk visual system #}

{# ── accent + emoji per category ── #}
{% set _accentMap = {
  "Tech & Data":          "#72d6ff",
  "Business & Finance":   "#4ade80",
  "Sales & Marketing":    "#fb923c",
  "People & HR":          "#f472b6",
  "Legal & Healthcare":   "#a78bfa"
} %}
{% set _emojiMap = {
  "Tech & Data":          "💻",
  "Business & Finance":   "📊",
  "Sales & Marketing":    "📈",
  "People & HR":          "🤝",
  "Legal & Healthcare":   "⚖️"
} %}
{% set _accent  = _accentMap[page.roleGroupLabel]  or "#72d6ff" %}
{% set _catEmoji = _emojiMap[page.roleGroupLabel] or "🎯" %}

<div class="rhub-page" style="--rc: {{ _accent }};">

{# ─── HERO ───────────────────────────────────────────────── #}
<section class="rhub-hero">
  <div class="container rhub-hero-inner">
    <div class="rhub-hero-left">
      <div class="rhub-emoji">{{ _catEmoji }}</div>
      <p class="rhub-eyebrow">{{ page.eyebrow }}</p>
      <h1 class="rhub-title">{{ page.h1 }}</h1>
      <p class="rhub-subtitle">{{ page.subtitle }}</p>
      {% if page.supporting %}
      <div class="rhub-answer">
        <span class="rhub-answer-label">Bottom line</span>
        <p>{{ page.supporting }}</p>
      </div>
      {% endif %}
      <div class="rhub-hero-cta">
        <a class="btn btn-primary" href="{{ page.ctaLink or site.cta.link }}">{{ page.ctaLabel or site.cta.label }}</a>
        <a class="btn btn-ghost" href="/resources/">View free resources</a>
      </div>
    </div>
    <div class="rhub-hero-stats">
      <div class="rhub-stat">
        <div class="rhub-stat-num">21 days</div>
        <p class="rhub-stat-body">Avg. time to first interview</p>
      </div>
      <div class="rhub-stat">
        <div class="rhub-stat-num">$47K</div>
        <p class="rhub-stat-body">Avg. salary increase negotiated</p>
      </div>
      <div class="rhub-stat">
        <div class="rhub-stat-num">89%</div>
        <p class="rhub-stat-body">Land offers within 60 days</p>
      </div>
    </div>
  </div>
</section>

{# ─── ROLES GRID ─────────────────────────────────────────── #}
<section class="rhub-guides">
  <div class="container">
    <h2 class="rhub-guides-title">{{ page.rolesTitle or "Coaching for your role" }}</h2>
    <p class="rhub-guides-sub">{{ page.rolesSubtitle or "Every role has unique challenges. We know your language, your hiring loops, and what gets you to the offer." }}</p>
    <div class="rhub-grid">
      {% for item in page.roles %}
      <a class="rhub-card" href="{{ item.url }}">
        <span class="rhub-card-topic">{{ page.roleGroupLabel }}</span>
        <h3 class="rhub-card-title">{{ item.label }}</h3>
        {% if item.note %}<p class="rhub-card-intro">{{ item.note }}</p>{% endif %}
        <span class="rhub-card-arrow">View coaching →</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ─── HOW IT WORKS ───────────────────────────────────────── #}
<section class="rhub-section rhub-section-alt">
  <div class="container">
    <h2 class="rhub-section-title">How it works</h2>
    <div class="rr-steps">
      <div class="rr-step">
        <div class="rr-step-num-bg" aria-hidden="true">1</div>
        <div class="rr-step-inner">
          <div class="rr-step-num-fg">1</div>
          <div class="rr-step-body">
            <h3 class="rr-step-title">Strategy call</h3>
            <p class="rr-step-desc">15 minutes. We figure out what's blocking you and map your fastest path to the right role.</p>
          </div>
        </div>
      </div>
      <div class="rr-step">
        <div class="rr-step-num-bg" aria-hidden="true">2</div>
        <div class="rr-step-inner">
          <div class="rr-step-num-fg">2</div>
          <div class="rr-step-body">
            <h3 class="rr-step-title">Build your signal</h3>
            <p class="rr-step-desc">Resume, LinkedIn, and pitch rebuilt to make hiring managers say "I need to talk to this person."</p>
          </div>
        </div>
      </div>
      <div class="rr-step">
        <div class="rr-step-num-bg" aria-hidden="true">3</div>
        <div class="rr-step-inner">
          <div class="rr-step-num-fg">3</div>
          <div class="rr-step-body">
            <h3 class="rr-step-title">Land and negotiate</h3>
            <p class="rr-step-desc">Interview prep, offer strategy, and negotiation coaching so you close with confidence.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ─── WHAT YOU GET ───────────────────────────────────────── #}
{% if page.highlights and page.highlights.length %}
<section class="rhub-section">
  <div class="container">
    <h2 class="rhub-section-title">What we focus on</h2>
    <div class="rhub-rules">
      <div class="rhub-rule-yes">
        <h3><span class="rhub-badge-yes">Included</span> What you walk away with</h3>
        <ul>
          {% for item in page.highlights %}
          <li><span>✓</span>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="rhub-rule-no">
        <h3><span class="rhub-badge-no">Not this</span> What we avoid</h3>
        <ul>
          <li><span>✗</span>Generic advice that doesn't map to your role or level</li>
          <li><span>✗</span>Templates you fill in yourself with no coaching</li>
          <li><span>✗</span>Surface-level edits that miss the underlying signal problem</li>
        </ul>
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ─── CTA ────────────────────────────────────────────────── #}
<section class="rhub-cta">
  <div class="container rhub-cta-inner">
    <h2>{{ page.ctaTitle or "Ready to target the right role?" }}</h2>
    <p>{{ page.ctaBody or "Book a free strategy call and leave with a clear plan for your next move." }}</p>
    <a class="btn btn-primary" href="{{ page.ctaLink or site.cta.link }}">{{ page.ctaLabel or site.cta.label }}</a>
  </div>
</section>

</div>

<script>
(function(){
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add('rr-revealed'); io.unobserve(e.target); }
      });
    },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.rr-step').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.rr-step').forEach(function(el){ el.classList.add('rr-revealed'); });
  }
})();
</script>
