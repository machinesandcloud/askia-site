<section class="section">
  <div class="container">
    <div class="pillar-header">
      <p class="hero-eyebrow">Top Markets</p>
      <h2 class="section-title section-title-glow">{{ featuredMarketsTitle or "Popular career coaching markets" }}</h2>
      <p class="section-subtitle">{{ featuredMarketsSubtitle or "Start with the market closest to your current search, then branch into the role or service track you need most." }}</p>
    </div>
    <div class="location-grid">
      {% for item in cities.items %}
        {% if loop.index <= 12 %}
        <a class="location-card" href="/{{ item.slug }}/">
          <strong>{{ item.label }}</strong>
          <span>{{ item.note }}</span>
        </a>
        {% endif %}
      {% endfor %}
    </div>
    <div class="hero-cta" style="justify-content:center; margin-top: 24px;">
      <a class="btn btn-ghost" href="/locations/">Browse all markets</a>
    </div>
  </div>
</section>
