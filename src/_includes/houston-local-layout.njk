---
layout: layout.njk
---
<section class="section">
  <div class="container hero-grid">
    <div class="hero-copy">
      {% if entry.eyebrow %}<p class="hero-eyebrow">{{ entry.eyebrow }}</p>{% endif %}
      <h1 class="hero-title section-title-glow">{{ entry.h1 }}</h1>
      <p class="hero-subtitle">{{ entry.subtitle }}</p>
      <p class="hero-support">{{ entry.intro }}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="{{ entry.primaryLink }}">{{ entry.primaryLabel }}</a>
        <a class="btn btn-ghost" href="{{ entry.secondaryLink }}">{{ entry.secondaryLabel }}</a>
      </div>
    </div>
    <div class="hero-card">
      <strong>What this page helps with</strong>
      <ul>
        {% for item in entry.bullets %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Quick answer</h2>
      <p>{{ entry.quickAnswer }}</p>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Best fit</h2>
      <ul class="checklist">
        {% for item in entry.bestFit %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">At a glance</h2>
      <ul class="checklist">
        <li>City focus: {{ entry.cityLabel }}</li>
        <li>Page intent: {{ entry.schemaServiceType }}</li>
        <li>Best fit: professionals who need sharper positioning, interviews, or negotiation signal</li>
        <li>Best next move: start with the city hub, then go narrower into the matching service or guide</li>
      </ul>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Proof snapshot</h2>
      <ul class="checklist">
        <li>147+ professionals coached across local and remote hiring markets</li>
        <li>4.9/5 average client rating across positioning, interview, and offer support</li>
        <li>89% of clients land offers within 60 days when they execute the plan consistently</li>
        <li>$47K average salary increase negotiated in compensation-focused engagements</li>
      </ul>
    </div>
  </div>
</section>

<section class="section">
  <div class="container two-col-grid">
    {% for section in entry.sections %}
    <div class="content-panel">
      <h2 class="section-title section-title-glow">{{ section.title }}</h2>
      <p>{{ section.body }}</p>
    </div>
    {% endfor %}
  </div>
</section>

{% if entry.signalPoints or entry.commonMistakes %}
<section class="section">
  <div class="container two-col-grid">
    {% if entry.signalPoints %}
    <div class="content-panel">
      <h2 class="section-title section-title-glow">What strong signal looks like</h2>
      <ul class="checklist">
        {% for item in entry.signalPoints %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if entry.commonMistakes %}
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Common mistakes</h2>
      <ul class="checklist">
        {% for item in entry.commonMistakes %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

<section class="section">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Best next pages from here</h2>
      <div class="link-stack">
        {% for item in entry.relatedLinks %}
        <a class="location-card" href="{{ item.url }}">
          <strong>{{ item.label }}</strong>
          <span>Related {{ entry.cityLabel }} and national career support</span>
        </a>
        {% endfor %}
        <a class="location-card" href="/blog/interview/">
          <strong>Interview guides</strong>
          <span>Structured interview pages for stronger live-loop conversion.</span>
        </a>
        <a class="location-card" href="/blog/salary/">
          <strong>Salary guides</strong>
          <span>Compensation and negotiation context for higher-quality offer decisions.</span>
        </a>
      </div>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Why this {{ entry.cityLabel }} page exists</h2>
      <p>This page is part of Askia's {{ entry.cityLabel }} local-intent cluster. It exists to answer a specific search intent clearly, then route you into the right coaching path without making you dig through generic service pages first.</p>
      <p>If this is the wrong page for your exact need, the {{ entry.cityLabel }} hub and related pages above will get you to the right one quickly.</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container faq-stage">
    <div class="faq-header">
      <h2 class="section-title section-title-glow">{{ entry.cityLabel }} FAQ</h2>
      <p class="section-subtitle">Short answers for people comparing coaching options in {{ entry.cityLabel }}.</p>
    </div>
    <div class="faq-grid">
      {% for item in entry.faq %}
      <details class="faq-card" {% if loop.first %}open{% endif %}>
        <summary>{{ item.q }}</summary>
        <p>{{ item.a }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container cta-band">
    <div>
      <h2 class="section-title">Need help with this in {{ entry.cityLabel }}?</h2>
      <p class="section-subtitle">Book a call and we’ll map the strongest next step for your search, interviews, and offer strategy.</p>
    </div>
    <a class="btn btn-primary" href="{{ site.cta.link }}">Book a Call</a>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": {{ entry.schemaName | dump | safe }},
    "description": {{ entry.schemaDescription | dump | safe }},
    "url": "{{ site.url }}{{ page.url }}",
    "serviceType": {{ entry.schemaServiceType | dump | safe }},
    "provider": {
      "@type": "ProfessionalService",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}"
    },
    "areaServed": {
      "@type": "Place",
      "name": {{ entry.cityLabel | dump | safe }}
    }
  }
</script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ entry.title | dump | safe }},
    "description": {{ entry.metaDescription | dump | safe }},
    "url": "{{ site.url }}{{ page.url }}"
  }
</script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": {{ (entry.title + " related pages") | dump | safe }},
    "itemListElement": [
      {% for item in entry.relatedLinks %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": {{ item.label | dump | safe }},
        "url": "{{ site.url }}{{ item.url }}"
      },
      {% endfor %}
      {
        "@type": "ListItem",
        "position": {{ entry.relatedLinks | length + 1 }},
        "name": "Interview guides",
        "url": "{{ site.url }}/blog/interview/"
      },
      {
        "@type": "ListItem",
        "position": {{ entry.relatedLinks | length + 2 }},
        "name": "Salary guides",
        "url": "{{ site.url }}/blog/salary/"
      }
    ]
  }
</script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in entry.faq %}
      {
        "@type": "Question",
        "name": {{ item.q | dump | safe }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ item.a | dump | safe }}
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
</script>
