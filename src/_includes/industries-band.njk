<section class="section band-collapsible industries-band" data-collapsible>
  <div class="container">
    <div class="band-collapsible-shell">
      <div class="band-hero">
        <div class="band-hero-text">
          <p class="hero-eyebrow">Industries</p>
          <h2 class="section-title section-title-glow">{{ industries.title }}</h2>
          {% if industries.subtitle %}<p class="section-subtitle">{{ industries.subtitle }}</p>{% endif %}
        </div>
        <div class="band-hero-actions">
          <button class="band-toggle" type="button" data-collapsible-toggle aria-expanded="false">
            <span>Explore industries</span>
            <span class="band-toggle-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
      <div class="band-panel" data-collapsible-panel>
        <div class="industry-line" aria-label="Industries">
          {% for item in industries.items %}
          <a class="industry-line-item reveal-item" href="/industries/{{ item.slug }}/">{{ item.label }}</a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
