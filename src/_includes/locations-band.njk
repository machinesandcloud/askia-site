<section class="section band-collapsible location-band" data-collapsible>
  <div class="container">
    <div class="band-collapsible-shell">
      <div class="band-hero">
        <div class="band-hero-text">
          <p class="hero-eyebrow">Markets</p>
          <h2 class="section-title section-title-glow">{{ locations.title }}</h2>
          {% if locations.subtitle %}<p class="section-subtitle">{{ locations.subtitle }}</p>{% endif %}
          {% if locations.remoteLine %}<p class="location-remote">{{ locations.remoteLine }}</p>{% endif %}
        </div>
        <div class="band-hero-actions">
          <button class="band-toggle" type="button" data-collapsible-toggle aria-expanded="false">
            <span>Explore markets</span>
            <span class="band-toggle-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
      <div class="band-panel" data-collapsible-panel>
        <div class="location-grid">
          {% for item in locations.items %}
          <div class="location-card reveal-item">
            <div class="location-card-header">
              <span class="location-dot"></span>
              <strong>{{ item.label }}</strong>
            </div>
            <span>{{ item.note }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
