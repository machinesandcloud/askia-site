<div class="resource-theme-page">
{% if page.visual and page.visual.style == 'next-role' %}
<section class="hero hero-themed hero-next-role hero-cro resource-theme-hero" style="--hero-next-accent: {{ page.visual.accent }}; --hero-next-accent-2: {{ page.visual.accent2 }};">
  <div class="container hero-next-grid">
    <div class="hero-next-copy">
      {% if page.eyebrow and (page.eyebrow | lower) != (page.h1 | lower) and (page.eyebrow | length) < 36 %}
        <p class="hero-eyebrow">{{ page.eyebrow }}</p>
      {% endif %}

      {# CRO: Single benefit-focused headline #}
      {% if page.titleLead %}
      <h1 class="hero-headline-cro">
        {{ page.titleLead }}<br>
        <span class="hero-headline-emphasis">{{ page.titleEmphasis }}</span>
        {% if page.titleAccent %}<span class="hero-headline-accent"><span class="title-strike title-accent">{{ page.titleAccent }}</span></span>{% endif %}
      </h1>
      {% else %}
      <h1 class="hero-headline-cro">{{ page.h1 }}</h1>
      {% endif %}

      {# CRO: Clear subheadline #}
      {% if page.subtitle %}<p class="hero-subheadline-cro">{{ page.subtitle }}</p>{% endif %}

      {# CRO: Benefit bullets (not chips) - what they GET #}
      {% if page.highlights and page.highlights.length %}
      <ul class="hero-benefits-cro">
        {% for item in page.highlights %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {# CRO: Single focused CTA with microcopy #}
      <div class="hero-cta-cro">
        <a class="btn btn-primary btn-lg btn-glow" href="{{ page.ctaLink or site.cta.link }}">{{ page.ctaLabel or site.cta.label }}</a>
        {% if page.ctaProof %}<span class="hero-microcopy-cro">{{ page.ctaProof }}</span>{% endif %}
      </div>

      {# CRO: Trust bar with rating + logos #}
      <div class="hero-trust-cro">
        {% if page.ctaRating %}<span class="hero-trust-rating-cro">★ {{ page.ctaRating }}/5 from {{ page.ctaRatingCount }} clients</span>{% endif %}
        {% if page.heroTrustLogos and page.heroTrustLogos.length %}
        <div class="hero-trust-logos-cro">
          <span>{{ page.heroTrustLabel or "Clients land at" }}</span>
          {% for item in page.heroTrustLogos %}
            <img src="{{ item.src }}" alt="{{ item.alt }}" loading="lazy" />
          {% endfor %}
        </div>
        {% endif %}
      </div>

      {# CRO: Urgency/scarcity message #}
      {% if page.ctaUrgency %}<p class="hero-urgency-cro" data-urgency>{{ page.ctaUrgency }}</p>{% endif %}
    </div>
    <div class="hero-visual-simple">
      {% if page.heroStats and page.heroStats.length %}
      <div class="hero-stats-card hero-stats-animated">
        {% for item in page.heroStats %}
          <div class="hero-stat-row stat-{{ loop.index }}">
            <div class="hero-stat-visual" aria-hidden="true">
              {% if loop.index == 1 %}
                <div class="stat-calendar">
                  <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
              {% elif loop.index == 2 %}
                <div class="stat-salary">
                  <span></span><span></span><span></span>
                </div>
              {% else %}
                <div class="stat-offer">
                  <span></span>
                </div>
              {% endif %}
            </div>
            <div class="hero-stat-copy">
              <strong>{{ item.value }}</strong>
              <span>{{ item.label }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
      {% endif %}
      {% if page.coach %}
      <div class="hero-coach-preview">
        <img src="{{ page.coach.photo }}" alt="{{ page.coach.name }}" class="hero-coach-photo" />
        <div class="hero-coach-info">
          <strong>{{ page.coach.name }}</strong>
          <span>{{ page.coach.role }}</span>
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% else %}
<section class="hero hero-themed{% if page.visual and page.visual.style %} hero-{{ page.visual.style }}{% endif %} resource-theme-hero">
  <div class="container hero-grid">
    <div>
      {% if page.eyebrow and (page.eyebrow | lower) != (page.h1 | lower) and (page.eyebrow | length) < 36 %}
        <p class="hero-eyebrow">{{ page.eyebrow }}</p>
      {% endif %}
      <h1 class="hero-title section-title-glow">{{ page.h1 }}</h1>
      {% if page.subtitle %}<p class="hero-subtitle">{{ page.subtitle }}</p>{% endif %}
      {% if page.supporting %}<p class="hero-supporting">{{ page.supporting }}</p>{% endif %}
      {% if page.highlights and page.highlights.length %}
      <ul class="highlight-list">
        {% for item in page.highlights %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      <div class="hero-cta">
        <a class="btn btn-primary" href="{{ page.ctaLink or site.cta.link }}">{{ page.ctaLabel or site.cta.label }}</a>
        {% if page.ctaProof %}<span class="hero-proof">{{ page.ctaProof }}</span>{% endif %}
      </div>
      {% if page.secondaryCtaLabel %}
        <p class="section-subtitle"><a class="btn btn-ghost" href="{{ page.secondaryCtaLink }}">{{ page.secondaryCtaLabel }}</a></p>
      {% endif %}
    </div>
    {% set heroImages = page.heroImages or site.heroImages %}
    <div class="hero-visual{% if page.visual and page.visual.style == 'signal-focus' %} hero-visual-focus{% elif page.visual and page.visual.style == 'signal-min' %} hero-visual-min{% else %} hero-visual-montage{% endif %}"{% if page.visual %} style="--visual-accent: {{ page.visual.accent }}; --visual-accent-2: {{ page.visual.accent2 }};"{% endif %}>
      {% if page.visual and page.visual.style == 'signal-focus' %}
        <div class="focus-main">
          {% if heroImages[0] %}
            <img src="{{ heroImages[0].src }}" alt="{{ heroImages[0].alt }}" loading="lazy" />
          {% endif %}
        </div>
        <div class="focus-stack">
          {% if heroImages[1] %}
            <div class="focus-thumb">
              <img src="{{ heroImages[1].src }}" alt="{{ heroImages[1].alt }}" loading="lazy" />
            </div>
          {% endif %}
          {% if page.heroCard %}
            <div class="focus-card">
              <strong>{{ page.heroCard.title }}</strong>
              {% if page.heroCard.body %}<p>{{ page.heroCard.body }}</p>{% endif %}
              {% if page.heroCard.bullets and page.heroCard.bullets.length %}
              <div class="focus-tags">
                {% for item in page.heroCard.bullets %}
                  <span>{{ item }}</span>
                {% endfor %}
              </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% elif page.visual and page.visual.style == 'signal-min' %}
        <div class="min-image">
          {% if heroImages[0] %}
            <img src="{{ heroImages[0].src }}" alt="{{ heroImages[0].alt }}" loading="lazy" />
          {% endif %}
        </div>
        {% if page.heroCard %}
          <div class="min-panel">
            <strong>{{ page.heroCard.title }}</strong>
            {% if page.heroCard.body %}<p>{{ page.heroCard.body }}</p>{% endif %}
            {% if page.heroCard.bullets and page.heroCard.bullets.length %}
              <div class="min-tags">
                {% for item in page.heroCard.bullets %}
                  <span>{{ item }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% else %}
        <div class="montage-stage">
          <div class="montage-grid">
            {% for item in heroImages %}
              <div class="montage-card montage-card-{{ loop.index }}">
                <img src="{{ item.src }}" alt="{{ item.alt }}" loading="lazy" />
              </div>
            {% endfor %}
          </div>
          {% if page.heroCard %}
          <div class="montage-overlay">
            <div class="visual-badge">
              <strong>{{ page.heroCard.title }}</strong>
              {% if page.heroCard.body %}<p>{{ page.heroCard.body }}</p>{% endif %}
              {% if page.heroCard.bullets and page.heroCard.bullets.length %}
              <div class="visual-tags">
                {% for item in page.heroCard.bullets %}
                  <span>{{ item }}</span>
                {% endfor %}
              </div>
              {% endif %}
            </div>
          </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

</div>

