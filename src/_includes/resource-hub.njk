{% set hubData = hub %}

{# Map hubData.theme to roleSubPages role slug #}
{% set roleSlug = "" %}
{% if hubData.theme == "swe" %}{% set roleSlug = "software-engineer" %}
{% elif hubData.theme == "devops" %}{% set roleSlug = "devops-sre" %}
{% elif hubData.theme == "data" %}{% set roleSlug = "data" %}
{% elif hubData.theme == "pm" %}{% set roleSlug = "product-manager" %}
{% elif hubData.theme == "em" %}{% set roleSlug = "engineering-manager" %}
{% elif hubData.theme == "finance" %}{% set roleSlug = "finance-fpa" %}
{% endif %}

{# Get role color from first matching page #}
{% set roleColor = "#72d6ff" %}
{% set roleEmoji = "📁" %}
{% for item in roleSubPages %}
  {% if item.role == roleSlug and roleColor == "#72d6ff" %}
    {% set roleColor = item.roleColor %}
    {% set roleEmoji = item.roleEmoji %}
  {% endif %}
{% endfor %}

<div class="rhub-page" style="--rc: {{ roleColor }};">

{# ── HERO ── #}
<section class="rhub-hero">
  <div class="container rhub-hero-inner">
    <div class="rhub-hero-left">
      <div class="rhub-emoji">{{ roleEmoji }}</div>
      <p class="rhub-eyebrow">{{ hubData.eyebrow }}</p>
      <h1 class="rhub-title">{{ hubData.title }}</h1>
      <p class="rhub-subtitle">{{ hubData.subtitle }}</p>
      {% if hubData.shortAnswer %}
      <div class="rhub-answer">
        <span class="rhub-answer-label">Bottom line</span>
        <p>{{ hubData.shortAnswer }}</p>
      </div>
      {% endif %}
      <div class="rhub-hero-cta">
        <a class="btn btn-primary" href="{{ site.cta.link }}">{{ site.cta.label }}</a>
        <a class="btn btn-ghost" href="/resources/">← All resources</a>
      </div>
    </div>
    {% if hubData.evidence %}
    <div class="rhub-hero-stats">
      {% for item in hubData.evidence %}
      <div class="rhub-stat">
        <div class="rhub-stat-num">{{ item.stat }}</div>
        <p class="rhub-stat-body">{{ item.body }}</p>
        {% if item.source %}<cite>{{ item.source }}</cite>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>

{# ── GUIDES GRID ── #}
{% if roleSlug %}
<section class="rhub-guides">
  <div class="container">
    <h2 class="rhub-guides-title">All guides in this track</h2>
    <p class="rhub-guides-sub">{{ roleSubPages | length }} guides specific to {{ hubData.title | replace("Career Resources","") | trim }} roles.</p>
    <div class="rhub-grid">
      {% for item in roleSubPages %}
        {% if item.role == roleSlug %}
        <a class="rhub-card" href="/resources/{{ item.role }}/{{ item.topic }}/">
          <span class="rhub-card-topic">{{ item.topicName }}</span>
          <h3 class="rhub-card-title">{{ item.headline }}</h3>
          <p class="rhub-card-intro">{{ item.shortAnswer }}</p>
          <span class="rhub-card-arrow">Read guide →</span>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── WHEN TO USE ── #}
{% if hubData.decisionRules %}
<section class="rhub-section rhub-section-alt">
  <div class="container">
    <h2 class="rhub-section-title">Is this track right for you?</h2>
    <div class="rhub-rules">
      <div class="rhub-rule-yes">
        <h3><span class="rhub-badge-yes">Use this track</span> If you…</h3>
        <ul>
          {% for r in hubData.decisionRules.doFirst %}
          <li><span>✓</span>{{ r }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="rhub-rule-no">
        <h3><span class="rhub-badge-no">Consider another track</span> If you…</h3>
        <ul>
          {% for r in hubData.decisionRules.skip %}
          <li><span>✗</span>{{ r }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ── FAQ ── #}
{% if hubData.faq %}
<section class="rhub-section">
  <div class="container rhub-faq-wrap">
    <h2 class="rhub-section-title">Common questions</h2>
    <div class="rhub-faq-list">
      {% for item in hubData.faq %}
      <details class="rhub-faq-item">
        <summary class="rhub-faq-q">{{ item.question }}<span class="rhub-faq-ico"></span></summary>
        <p class="rhub-faq-a">{{ item.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── CTA ── #}
<section class="rhub-cta">
  <div class="container rhub-cta-inner">
    <h2>{{ hubData.cta.title or "Ready to land your next role?" }}</h2>
    <p>{{ hubData.cta.body or "Book a strategy call and get personalized guidance." }}</p>
    <a class="btn btn-primary" href="{{ site.cta.link }}">{{ site.cta.label }}</a>
  </div>
</section>

</div>

{% if hubData.faq %}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{% for item in hubData.faq %}{"@type":"Question","name":"{{ item.question | replace('"','&quot;') }}","acceptedAnswer":{"@type":"Answer","text":"{{ item.answer | replace('"','&quot;') }}"}}{% if not loop.last %},{% endif %}{% endfor %}]}
</script>
{% endif %}
