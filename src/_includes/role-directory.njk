<section class="section section-tight role-directory">
  <div class="container">
    <div class="band-shell">
      <div class="band-rail">
        <p class="hero-eyebrow">Role Directory</p>
        <h2 class="section-title section-title-glow">{{ roleDirectory.title }}</h2>
        {% if roleDirectory.subtitle %}<p class="section-subtitle">{{ roleDirectory.subtitle }}</p>{% endif %}
        <div class="band-rail-cta">
          <a class="btn btn-primary" href="{{ site.cta.link }}">Book a Call</a>
        </div>
      </div>
      <div class="band-body">
        <div class="role-directory-grid">
          {% for group in roleDirectory.groups %}
          <div class="role-directory-group reveal-item">
            <div class="role-directory-group-header">
              <span class="role-directory-dot"></span>
              <strong>{{ group.label }}</strong>
            </div>
            <div class="role-directory-list">
              {% for item in group.items %}
              <a class="role-directory-item" href="{{ item.url }}">{{ item.label }}</a>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
