<section class="section band-collapsible role-directory" data-collapsible>
  <div class="container">
    <div class="band-collapsible-shell">
      <div class="band-hero">
        <div class="band-hero-text">
          <p class="hero-eyebrow">Role Directory</p>
          <h2 class="section-title section-title-glow">{{ roleDirectory.title }}</h2>
          {% if roleDirectory.subtitle %}<p class="section-subtitle">{{ roleDirectory.subtitle }}</p>{% endif %}
        </div>
        <div class="band-hero-actions">
          <button class="band-toggle" type="button" data-collapsible-toggle aria-expanded="false">
            <span>Explore roles</span>
            <span class="band-toggle-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
      <div class="band-panel" data-collapsible-panel>
        <div class="role-line" aria-label="Role tracks">
          {% for group in roleDirectory.groups %}
            {% for item in group.items %}
            <a class="role-line-item reveal-item" href="{{ item.url }}">{{ item.label }}</a>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
