{# CRO-Optimized Role Page Template #}
{# Streamlined for maximum conversion following Executive Summary principles #}

<div class="role-page" style="--role-accent: {{ page.visual.accent }}; --role-accent-2: {{ page.visual.accent2 }};">

{# HERO SECTION - Benefit-focused with trust signals #}
<section class="hero hero-role">
  <div class="container hero-role-grid">
    <div class="hero-role-content">
      {% if page.eyebrow %}<p class="hero-eyebrow">{{ page.eyebrow }}</p>{% endif %}

      <h1 class="hero-headline-cro">{{ page.h1 }}</h1>

      {% if page.subtitle %}<p class="hero-subheadline-cro">{{ page.subtitle }}</p>{% endif %}

      {% if page.highlights and page.highlights.length %}
      <ul class="hero-benefits-cro">
        {% for item in page.highlights %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      <div class="hero-cta-cro">
        <a class="btn btn-primary btn-lg btn-glow" href="{{ page.ctaLink or site.cta.link }}">{{ page.ctaLabel or "Get My Free Strategy Session" }}</a>
        <span class="hero-microcopy-cro">{{ page.ctaProof or "15 minutes. No sales pitch. Leave with a clear action plan." }}</span>
      </div>

      <div class="hero-trust-cro">
        <span class="hero-trust-rating-cro">★ 4.9/5 from 147+ professionals</span>
      </div>

      <p class="hero-urgency-cro" data-urgency>{{ page.ctaUrgency or "Only 4 spots left this week" }}</p>
    </div>

    <div class="hero-role-visual">
      <div class="hero-stats-card">
        {% if page.proof and page.proof.items %}
          {% for item in page.proof.items %}
            <div class="hero-stat-row">
              <strong>{{ item.title }}</strong>
              <span>{{ item.body }}</span>
            </div>
          {% endfor %}
        {% else %}
          <div class="hero-stat-row">
            <strong>21 days</strong>
            <span>avg. to first interview</span>
          </div>
          <div class="hero-stat-row">
            <strong>$47K</strong>
            <span>avg. salary increase</span>
          </div>
          <div class="hero-stat-row">
            <strong>89%</strong>
            <span>land offers in 60 days</span>
          </div>
        {% endif %}
      </div>
      <div class="hero-guarantee-badge">
        <span>✓</span>
        Leave with a clear action plan — guaranteed
      </div>
    </div>
  </div>
</section>

{# SOCIAL PROOF BAR #}
<section class="section section-tight">
  <div class="container">
    <div class="category-proof-bar">
      <div class="proof-item">
        <strong>147+</strong>
        <span>professionals coached</span>
      </div>
      <div class="proof-item">
        <strong>4.9★</strong>
        <span>average rating</span>
      </div>
      <div class="proof-item">
        <strong>89%</strong>
        <span>land offers in 60 days</span>
      </div>
      <div class="proof-item">
        <strong>$47K</strong>
        <span>avg. salary increase</span>
      </div>
    </div>
  </div>
</section>

{# WHAT YOU GET - Simplified benefits #}
<section class="section">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">{{ page.focus.eyebrow or "What You Get" }}</p>
      <h2 class="section-title section-title-glow">{{ page.focus.title }}</h2>
      {% if page.focus.subtitle %}<p class="section-subtitle">{{ page.focus.subtitle }}</p>{% endif %}
    </div>
    <div class="focus-grid">
      {% for item in page.focus.items | slice(0, 3) %}
        <article class="focus-card">
          <span class="focus-tag">{{ item.tag }}</span>
          <h3>{{ item.title }}</h3>
          <p>{{ item.body }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{# TESTIMONIALS - Social proof near CTA #}
<section class="section section-testimonials">
  <div class="container">
    <div class="testimonials-header" style="text-align: center;">
      <p class="hero-eyebrow">Success Stories</p>
      <h2 class="section-title section-title-glow">People who made the leap</h2>
      <div class="testimonials-summary">
        <span class="testimonials-rating">★★★★★ 4.9/5</span>
        <span>from 147+ professionals</span>
      </div>
    </div>
    <div class="testimonials-carousel" data-testimonials-carousel>
      <div class="testimonials-track" data-testimonials-track>
        {% for item in testimonials.items | slice(0, 6) %}
        <article class="testimonial-card-home" data-testimonial-card>
          <div class="testimonial-card-header">
            <img class="testimonial-avatar" src="{{ item.photo }}" alt="{{ item.name }}" loading="lazy" />
            <div>
              <strong>{{ item.name }}</strong>
              <span>{{ item.role }}{% if item.company %} · {{ item.company }}{% endif %}</span>
            </div>
          </div>
          <div class="testimonial-card-rating">★★★★★</div>
          <p class="testimonial-card-quote">"{{ item.quote | truncate(180) }}"</p>
        </article>
        {% endfor %}
        {% for item in testimonials.items | slice(0, 6) %}
        <article class="testimonial-card-home" data-testimonial-card>
          <div class="testimonial-card-header">
            <img class="testimonial-avatar" src="{{ item.photo }}" alt="{{ item.name }}" loading="lazy" />
            <div>
              <strong>{{ item.name }}</strong>
              <span>{{ item.role }}{% if item.company %} · {{ item.company }}{% endif %}</span>
            </div>
          </div>
          <div class="testimonial-card-rating">★★★★★</div>
          <p class="testimonial-card-quote">"{{ item.quote | truncate(180) }}"</p>
        </article>
        {% endfor %}
      </div>
      <div class="testimonials-focus-glow" aria-hidden="true"></div>
    </div>
  </div>
</section>

{# MID-PAGE CTA - Capture convinced visitors #}
<section class="section section-mid-cta">
  <div class="container">
    <div class="mid-cta-band">
      <div class="mid-cta-content">
        <h3>Ready to accelerate your career?</h3>
        <p>Book a free strategy call and leave with a clear action plan.</p>
      </div>
      <a class="btn btn-primary btn-lg btn-glow" href="{{ page.ctaLink or site.cta.link }}">{{ page.ctaLabel or "Book My Free Strategy Call" }}</a>
    </div>
  </div>
</section>

{# HOW IT WORKS - Simple 3-step process #}
<section class="section">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">How It Works</p>
      <h2 class="section-title section-title-glow">{{ page.steps.title or "From stuck to hired in 3 steps" }}</h2>
    </div>
    <div class="category-process">
      {% for step in page.steps.items | slice(0, 3) %}
        <div class="process-step">
          <div class="process-number">{{ loop.index }}</div>
          <h3>{{ step.title }}</h3>
          <p>{{ step.body }}</p>
        </div>
        {% if not loop.last %}<div class="process-connector" aria-hidden="true"></div>{% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{# DELIVERABLES - What you'll get #}
{% if page.deliverables %}
<section class="section section-soft">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">Deliverables</p>
      <h2 class="section-title section-title-glow">{{ page.deliverables.title }}</h2>
      {% if page.deliverables.subtitle %}<p class="section-subtitle">{{ page.deliverables.subtitle }}</p>{% endif %}
    </div>
    <div class="role-category-grid-enhanced">
      {% for item in page.deliverables.items %}
        <div class="role-card-enhanced" style="display: block; cursor: default;">
          <div class="role-card-content">
            <strong>{{ item.title }}</strong>
            <p style="margin-top: 8px; color: var(--muted); font-size: 0.9rem;">{{ item.body }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# COACH SECTION - Build trust #}
<section class="section">
  <div class="container">
    <div class="category-coach-preview">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Askia Career Coach" class="category-coach-photo" />
      <div class="category-coach-content">
        <p class="hero-eyebrow">Your Coach</p>
        <h3 class="section-title">{{ page.coach.title or "Steve gets your world" }}</h3>
        <p>{{ page.coach.bio or "10+ years leading teams across tech companies. Hundreds of professionals coached into roles at Google, Amazon, Meta, and high-growth startups. I've sat on the other side of the table — I know exactly what makes someone stand out." }}</p>
        <div class="category-coach-stats">
          {% if page.coach.stats %}
            {% for stat in page.coach.stats %}
            <span><strong>{{ stat.value }}</strong> {{ stat.label }}</span>
            {% endfor %}
          {% else %}
            <span><strong>10+</strong> years experience</span>
            <span><strong>147+</strong> professionals coached</span>
            <span><strong>$47K</strong> avg. raise negotiated</span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{# WHO THIS IS FOR / NOT FOR #}
<section class="section">
  <div class="container services-preview">
    <div class="card card-soft">
      <strong>{{ page.for.title }}</strong>
      <p>{{ page.for.body }}</p>
      {% if page.for.items and page.for.items.length %}
      <ul class="highlight-list">
        {% for item in page.for.items %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    <div class="card">
      <strong>{{ page.notFor.title }}</strong>
      <p>{{ page.notFor.body }}</p>
      {% if page.notFor.items and page.notFor.items.length %}
      <ul class="highlight-list">
        {% for item in page.notFor.items %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </div>
</section>

{# FAQ - Handle objections #}
<section class="section">
  <div class="container faq-stage">
    <div class="faq-header">
      <h2 class="section-title section-title-glow">{{ page.faq.title }}</h2>
      {% if page.faq.subtitle %}<p class="section-subtitle">{{ page.faq.subtitle }}</p>{% endif %}
    </div>
    <div class="faq-grid">
      {% for item in page.faq.items %}
        <details class="faq-card">
          <summary>{{ item.question }}</summary>
          <p>{{ item.answer }}</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{# FINAL CTA - With testimonial and urgency #}
<section class="section section-cta-final">
  <div class="container">
    {% if page.related and page.related.miniTestimonial %}
    <div class="cta-testimonial-mini">
      <p>"{{ page.related.miniTestimonial.quote }}"</p>
      <span>★★★★★ — {{ page.related.miniTestimonial.name }}, {{ page.related.miniTestimonial.role }}</span>
    </div>
    {% else %}
    <div class="cta-testimonial-mini">
      <p>"Within 3 weeks I had 4 interviews lined up. Steve completely changed how I talk about my work."</p>
      <span>★★★★★ — Marcus T., Senior Engineer → Staff at FAANG</span>
    </div>
    {% endif %}
    <div class="cta-band">
      <div>
        <h2 class="section-title">{{ page.cta.title }}</h2>
        <p class="section-subtitle">{{ page.cta.body }}</p>
        <p class="cta-proof">Join 147+ professionals who've accelerated their careers</p>
      </div>
      <div class="cta-action">
        <a class="btn btn-primary btn-lg btn-glow" href="{{ page.cta.link or site.cta.link }}">{{ page.cta.label or "Claim My Free Strategy Session" }}</a>
        <span class="cta-urgency" data-urgency>Only 4 spots left this week</span>
        <span class="cta-guarantee">✓ Leave with a clear action plan or get a second session free</span>
      </div>
    </div>
  </div>
</section>

</div>

{% if page.faq and page.faq.items %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in page.faq.items %}
    {
      "@type": "Question",
      "name": "{{ item.question | escape }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.answer | escape }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
