{# Role coaching page — redesigned to match resource-hub.njk visual system #}

{# ── slug → emoji map (matches roleTracks.js) ── #}
{% set _emojiMap = {
  "software-engineer-career-coaching":       "⚙️",
  "devops-career-coaching":                  "🛡️",
  "data-career-coaching":                    "📊",
  "product-manager-career-coaching":         "🧭",
  "engineering-manager-coaching":            "👥",
  "cybersecurity-career-coaching":           "🔐",
  "product-design-career-coaching":          "🎨",
  "solutions-architect-career-coaching":     "🏗️",
  "technical-program-manager-coaching":      "📋",
  "ai-ml-career-coaching":                   "🤖",
  "finance-fpa-career-coaching":             "📈",
  "accounting-controller-coaching":          "🧾",
  "operations-career-coaching":              "⚙️",
  "supply-chain-career-coaching":            "🚢",
  "strategy-consulting-career-coaching":     "♟️",
  "sales-career-coaching":                   "💼",
  "sales-engineer-career-coaching":          "🔧",
  "customer-success-career-coaching":        "🤝",
  "marketing-career-coaching":               "📣",
  "people-career-coaching":                  "💛",
  "people-ops-career-coaching":              "💛",
  "qa-career-coaching":                      "🧪",
  "project-program-management-coaching":     "📅",
  "legal-compliance-career-coaching":        "⚖️",
  "healthcare-administration-career-coaching":"🏥"
} %}
{% set _roleEmoji = _emojiMap[page.fileSlug] or "🎯" %}
{% set _accent    = roleData.visual.accent   or "#72d6ff" %}

<div class="rhub-page" style="--rc: {{ _accent }};">

{# ─── HERO ───────────────────────────────────────────────── #}
<section class="rhub-hero">
  <div class="container rhub-hero-inner">
    <div class="rhub-hero-left">
      <div class="rhub-emoji">{{ _roleEmoji }}</div>
      <p class="rhub-eyebrow">{{ roleData.eyebrow }}</p>
      <h1 class="rhub-title">{{ roleData.h1 }}</h1>
      <p class="rhub-subtitle">{{ roleData.subtitle }}</p>
      {% if roleData.supporting %}
      <div class="rhub-answer">
        <span class="rhub-answer-label">Bottom line</span>
        <p>{{ roleData.supporting }}</p>
      </div>
      {% endif %}
      <div class="rhub-hero-cta">
        <a class="btn btn-primary" href="{{ roleData.ctaLink or site.cta.link }}">{{ roleData.ctaLabel or site.cta.label }}</a>
        <a class="btn btn-ghost" href="/resources/">View free resources</a>
      </div>
    </div>
    <div class="rhub-hero-stats">
      <div class="rhub-stat">
        <div class="rhub-stat-num">21 days</div>
        <p class="rhub-stat-body">Avg. time to first interview</p>
      </div>
      <div class="rhub-stat">
        <div class="rhub-stat-num">$47K</div>
        <p class="rhub-stat-body">Avg. salary increase negotiated</p>
      </div>
      <div class="rhub-stat">
        <div class="rhub-stat-num">89%</div>
        <p class="rhub-stat-body">Land offers within 60 days</p>
      </div>
    </div>
  </div>
</section>

{# ─── WHAT YOU GET ────────────────────────────────────────── #}
{% if roleData.focus and roleData.focus.items %}
<section class="rhub-guides">
  <div class="container">
    <p class="rhub-eyebrow" style="margin-bottom: 6px;">{{ roleData.focus.eyebrow or "What you get" }}</p>
    <h2 class="rhub-guides-title">{{ roleData.focus.title }}</h2>
    {% if roleData.focus.subtitle %}
    <p class="rhub-guides-sub">{{ roleData.focus.subtitle }}</p>
    {% endif %}
    <div class="rhub-grid">
      {% for item in roleData.focus.items %}
      <div class="rhub-card" style="cursor: default;">
        <span class="rhub-card-topic">{{ item.tag }}</span>
        <h3 class="rhub-card-title">{{ item.title }}</h3>
        <p class="rhub-card-intro">{{ item.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ─── HOW IT WORKS ────────────────────────────────────────── #}
{% if roleData.steps and roleData.steps.items %}
<section class="rhub-section rhub-section-alt">
  <div class="container">
    <h2 class="rhub-section-title">{{ roleData.steps.title or "How it works" }}</h2>
    <div class="rr-steps">
      {% for step in roleData.steps.items %}
      <div class="rr-step">
        <div class="rr-step-num-bg" aria-hidden="true">{{ loop.index }}</div>
        <div class="rr-step-inner">
          <div class="rr-step-num-fg">{{ loop.index }}</div>
          <div class="rr-step-body">
            <h3 class="rr-step-title">{{ step.title }}</h3>
            <p class="rr-step-desc">{{ step.body }}</p>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ─── IS THIS RIGHT FOR YOU? ─────────────────────────────── #}
{% if roleData.for or roleData.notFor %}
<section class="rhub-section">
  <div class="container">
    <h2 class="rhub-section-title">Is this right for you?</h2>
    <div class="rhub-rules">
      {% if roleData.for %}
      <div class="rhub-rule-yes">
        <h3><span class="rhub-badge-yes">Good fit</span> {{ roleData.for.title or "This is for you if…" }}</h3>
        <ul>
          {% for item in roleData.for.items %}
          <li><span>✓</span>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if roleData.notFor %}
      <div class="rhub-rule-no">
        <h3><span class="rhub-badge-no">Skip this</span> {{ roleData.notFor.title or "Not the right fit if…" }}</h3>
        <ul>
          {% for item in roleData.notFor.items %}
          <li><span>✗</span>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ─── FAQ ─────────────────────────────────────────────────── #}
{% if roleData.faq and roleData.faq.items %}
<section class="rhub-section rhub-section-alt">
  <div class="container rhub-faq-wrap">
    <h2 class="rhub-section-title">{{ roleData.faq.title or "Common questions" }}</h2>
    <div class="rhub-faq-list">
      {% for item in roleData.faq.items %}
      <details class="rhub-faq-item">
        <summary class="rhub-faq-q">{{ item.question }}<span class="rhub-faq-ico"></span></summary>
        <p class="rhub-faq-a">{{ item.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ─── CTA ─────────────────────────────────────────────────── #}
<section class="rhub-cta">
  <div class="container rhub-cta-inner">
    <h2>{{ roleData.cta.title if roleData.cta else "Ready to land your next role?" }}</h2>
    <p>{{ roleData.cta.body if roleData.cta else "Book a free strategy call and leave with a clear action plan." }}</p>
    <a class="btn btn-primary" href="{{ roleData.cta.link if roleData.cta else (roleData.ctaLink or site.cta.link) }}">{{ roleData.cta.label if roleData.cta else (roleData.ctaLabel or site.cta.label) }}</a>
  </div>
</section>

</div>

<script>
(function(){
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add('rr-revealed'); io.unobserve(e.target); }
      });
    },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.rr-step').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.rr-step').forEach(function(el){ el.classList.add('rr-revealed'); });
  }
})();
</script>

{% if roleData.faq and roleData.faq.items %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in roleData.faq.items %}
    {
      "@type": "Question",
      "name": "{{ item.question | replace('"', '&quot;') }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.answer | replace('"', '&quot;') }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
