{# Service Page — redesigned to match resource-hub.njk visual system #}
{# Uses rhub- CSS classes for visual consistency with /resources/ pages      #}

{# ── theme → emoji map ── #}
{% set _emojiMap = {
  "resume":       "📄",
  "linkedin":     "🔗",
  "interview":    "🎯",
  "salary":       "💰",
  "cover-letter": "✉️",
  "done-for-you": "🚀",
  "offer":        "📋",
  "job-search":   "🗺️",
  "ongoing":      "🔄",
  "career":       "🧭"
} %}
{% set _serviceEmoji = _emojiMap[serviceData.theme] or "💼" %}

{# ── accent color from serviceData.visual.accent ── #}
{% set _accent = serviceData.visual.accent or "#72d6ff" %}

<div class="rhub-page" style="--rc: {{ _accent }};">

{# ─── HERO ───────────────────────────────────────────────── #}
<section class="rhub-hero">
  <div class="container rhub-hero-inner">
    <div class="rhub-hero-left">
      <div class="rhub-emoji">{{ _serviceEmoji }}</div>
      <p class="rhub-eyebrow">{{ serviceData.eyebrow }}</p>
      <h1 class="rhub-title">{{ serviceData.h1 }}</h1>
      <p class="rhub-subtitle">{{ serviceData.subtitle }}</p>
      {% if serviceData.quickAnswer %}
      <div class="rhub-answer">
        <span class="rhub-answer-label">Bottom line</span>
        <p>{{ serviceData.quickAnswer }}</p>
      </div>
      {% endif %}
      <div class="rhub-hero-cta">
        <a class="btn btn-primary" href="{{ serviceData.ctaLink or site.cta.link }}">{{ serviceData.ctaLabel or site.cta.label }}</a>
        <a class="btn btn-ghost" href="/services/">← All services</a>
      </div>
      <div class="hero-trust-cro">
        <span class="hero-trust-rating-cro">★ 4.9/5 from 147+ professionals</span>
      </div>
      <p class="hero-urgency-cro" data-urgency>Only 4 spots left this week</p>
    </div>

    {# ── proof stats ── #}
    <div class="rhub-hero-stats">
      {% if serviceData.heroStats %}
        {% for s in serviceData.heroStats %}
        <div class="rhub-stat">
          <div class="rhub-stat-num">{{ s.value }}</div>
          <p class="rhub-stat-body">{{ s.label }}</p>
        </div>
        {% endfor %}
      {% else %}
        <div class="rhub-stat">
          <div class="rhub-stat-num">21 days</div>
          <p class="rhub-stat-body">Avg. time to first interview</p>
        </div>
        <div class="rhub-stat">
          <div class="rhub-stat-num">$47K</div>
          <p class="rhub-stat-body">Avg. salary increase negotiated</p>
        </div>
        <div class="rhub-stat">
          <div class="rhub-stat-num">89%</div>
          <p class="rhub-stat-body">Land offers within 60 days</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{# ─── WHAT YOU GET ────────────────────────────────────────── #}
{% if serviceData.focus and serviceData.focus.items %}
<section class="rhub-guides">
  <div class="container">
    <p class="rhub-eyebrow" style="margin-bottom: 6px;">{{ serviceData.focus.eyebrow or "What you get" }}</p>
    <h2 class="rhub-guides-title">{{ serviceData.focus.title }}</h2>
    {% if serviceData.focus.subtitle %}
    <p class="rhub-guides-sub">{{ serviceData.focus.subtitle }}</p>
    {% endif %}
    <div class="rhub-grid">
      {% for item in serviceData.focus.items %}
      <div class="rhub-card" style="cursor: default;">
        <span class="rhub-card-topic">{{ item.tag }}</span>
        <h3 class="rhub-card-title">{{ item.title }}</h3>
        <p class="rhub-card-intro">{{ item.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ─── HOW IT WORKS ────────────────────────────────────────── #}
{% if serviceData.steps and serviceData.steps.items %}
<section class="rhub-section">
  <div class="container">
    <h2 class="rhub-section-title">{{ serviceData.steps.title or "How it works" }}</h2>
    {% if serviceData.steps.subtitle %}
    <p style="color: var(--muted); margin: 0 0 40px; font-size: .93rem;">{{ serviceData.steps.subtitle }}</p>
    {% endif %}
    <div class="rr-steps">
      {% for step in serviceData.steps.items %}
      <div class="rr-step">
        <div class="rr-step-num-bg" aria-hidden="true">{{ loop.index }}</div>
        <div class="rr-step-inner">
          <div class="rr-step-num-fg">{{ loop.index }}</div>
          <div class="rr-step-body">
            <h3 class="rr-step-title">{{ step.title }}</h3>
            <p class="rr-step-desc">{{ step.body }}</p>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ─── IS THIS RIGHT FOR YOU? ─────────────────────────────── #}
{% if serviceData.for or serviceData.notFor %}
<section class="rhub-section rhub-section-alt">
  <div class="container">
    <h2 class="rhub-section-title">Is this right for you?</h2>
    <div class="rhub-rules">
      {% if serviceData.for %}
      <div class="rhub-rule-yes">
        <h3><span class="rhub-badge-yes">Good fit</span> {{ serviceData.for.title or "This is for you if…" }}</h3>
        <ul>
          {% for item in serviceData.for.items %}
          <li><span>✓</span>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if serviceData.notFor %}
      <div class="rhub-rule-no">
        <h3><span class="rhub-badge-no">Skip this</span> {{ serviceData.notFor.title or "Not the right fit if…" }}</h3>
        <ul>
          {% for item in serviceData.notFor.items %}
          <li><span>✗</span>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ─── FAQ ─────────────────────────────────────────────────── #}
{% if serviceData.faq and serviceData.faq.items %}
<section class="rhub-section">
  <div class="container rhub-faq-wrap">
    <h2 class="rhub-section-title">{{ serviceData.faq.title or "Common questions" }}</h2>
    <div class="rhub-faq-list">
      {% for item in serviceData.faq.items %}
      <details class="rhub-faq-item">
        <summary class="rhub-faq-q">{{ item.question }}<span class="rhub-faq-ico"></span></summary>
        <p class="rhub-faq-a">{{ item.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ─── CTA ─────────────────────────────────────────────────── #}
<section class="rhub-cta">
  <div class="container rhub-cta-inner">
    <h2>{{ serviceData.cta.title if serviceData.cta else "Ready to get started?" }}</h2>
    <p>{{ serviceData.cta.body if serviceData.cta else "Book a free strategy call and leave with a clear action plan." }}</p>
    <a class="btn btn-primary" href="{{ serviceData.cta.link if serviceData.cta else (serviceData.ctaLink or site.cta.link) }}">{{ serviceData.cta.label if serviceData.cta else (serviceData.ctaLabel or site.cta.label) }}</a>
  </div>
</section>

</div>

<script>
(function(){
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add('rr-revealed'); io.unobserve(e.target); }
      });
    },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.rr-step').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.rr-step').forEach(function(el){ el.classList.add('rr-revealed'); });
  }
})();
</script>

{# ─── SCHEMA ──────────────────────────────────────────────── #}
{% if serviceData.faq and serviceData.faq.items %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in serviceData.faq.items %}
    {
      "@type": "Question",
      "name": "{{ item.question | replace('"', '&quot;') }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.answer | replace('"', '&quot;') }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ (serviceData.h1 or title) | dump | safe }},
  "description": {{ (serviceData.metaDescription or serviceData.subtitle or description) | dump | safe }},
  "url": "{{ site.url }}{{ page.url }}",
  "provider": {
    "@type": "ProfessionalService",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "serviceType": {{ (serviceData.eyebrow or "Career coaching service") | dump | safe }}
}
</script>
