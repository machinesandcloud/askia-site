{# CRO-Optimized Service Page Template #}
{# Streamlined for maximum conversion following Executive Summary principles #}
{% set serviceDepth = serviceCopyDepth[page.fileSlug] or serviceCopyDepth.default %}
{% set relatedCaseStudies = caseStudies.byService[page.fileSlug] or [] %}
{% set relatedDecisionGuides = citySupportPages.byService[page.fileSlug] or [] %}

<div class="service-page resource-theme-page" style="--theme-accent: {{ serviceData.visual.accent }}; --theme-accent-2: {{ serviceData.visual.accent2 }};">

{# HERO SECTION - Benefit-focused with trust signals #}
<section class="hero hero-service resource-theme-hero">
  <div class="container hero-service-grid">
    <div class="hero-service-content">
      {% if serviceData.eyebrow %}<p class="hero-eyebrow">{{ serviceData.eyebrow }}</p>{% endif %}

      <h1 class="hero-headline-cro">{{ serviceData.h1 }}</h1>

      {% if serviceData.subtitle %}<p class="hero-subheadline-cro">{{ serviceData.subtitle }}</p>{% endif %}

      {% if serviceData.highlights and serviceData.highlights.length %}
      <ul class="hero-benefits-cro">
        {% for item in serviceData.highlights %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      <div class="hero-cta-cro">
        <a class="btn btn-primary btn-lg btn-glow" href="{{ serviceData.ctaLink or site.cta.link }}">{{ serviceData.ctaLabel or "Get My Free Strategy Session" }}</a>
        <span class="hero-microcopy-cro">{{ serviceData.ctaProof or "15 minutes. No sales pitch. Leave with a clear action plan." }}</span>
      </div>

      <div class="hero-trust-cro">
        <span class="hero-trust-rating-cro">★ 4.9/5 from 147+ professionals</span>
      </div>

      <p class="hero-urgency-cro" data-urgency>{{ serviceData.ctaUrgency or "Only 4 spots left this week" }}</p>
    </div>

    <div class="hero-service-visual">
      <div class="hero-stats-card hero-stats-animated">
        <div class="hero-stat-row stat-1">
          <div class="hero-stat-visual" aria-hidden="true">
            <div class="stat-calendar">
              <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
          </div>
          <div class="hero-stat-copy">
            <strong>21 days</strong>
            <span>Average time to first interview</span>
          </div>
        </div>
        <div class="hero-stat-row stat-2">
          <div class="hero-stat-visual" aria-hidden="true">
            <div class="stat-salary">
              <span></span><span></span><span></span>
            </div>
          </div>
          <div class="hero-stat-copy">
            <strong>$47K</strong>
            <span>Average salary increase negotiated</span>
          </div>
        </div>
        <div class="hero-stat-row stat-3">
          <div class="hero-stat-visual" aria-hidden="true">
            <div class="stat-offer">
              <span></span>
            </div>
          </div>
          <div class="hero-stat-copy">
            <strong>89%</strong>
            <span>Land offers within 60 days</span>
          </div>
        </div>
      </div>
      <div class="hero-coach-preview">
        <img src="/assets/steve-headshot.jpg" alt="Steve J. Ngoumnai" class="hero-coach-photo" />
        <div class="hero-coach-info">
          <strong>Steve J. Ngoumnai</strong>
          <span>Founder, Head Career Coach</span>
        </div>
      </div>
    </div>
  </div>
</section>

{# SOCIAL PROOF BAR #}
<section class="section section-tight">
  <div class="container">
    <div class="category-proof-bar">
      <div class="proof-item">
        <strong>147+</strong>
        <span>professionals coached</span>
      </div>
      <div class="proof-item">
        <strong>4.9★</strong>
        <span>average rating</span>
      </div>
      <div class="proof-item">
        <strong>89%</strong>
        <span>land offers in 60 days</span>
      </div>
      <div class="proof-item">
        <strong>$47K</strong>
        <span>avg. salary increase</span>
      </div>
    </div>
  </div>
</section>

{% if serviceData.quickAnswer or serviceData.bestFit %}
<section class="section section-tight">
  <div class="container two-col-grid">
    {% if serviceData.quickAnswer %}
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Quick answer</h2>
      <p>{{ serviceData.quickAnswer }}</p>
    </div>
    {% endif %}
    {% if serviceData.bestFit %}
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Best fit</h2>
      <ul class="checklist">
        {% for item in serviceData.bestFit %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</section>

<section class="section section-tight">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Why Askia is credible here</h2>
      <p>{{ expertCredibility.founder.shortBio }}</p>
      <ul class="checklist">
        {% for item in expertCredibility.founder.highlights %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Proof behind the coaching</h2>
      <ul class="checklist">
        {% for item in expertCredibility.founder.metrics %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% if relatedCaseStudies.length %}
<section class="section">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">Proof</p>
      <h2 class="section-title section-title-glow">Relevant case studies</h2>
      <p class="section-subtitle">Examples of how stronger positioning changes interviews and offers.</p>
    </div>
    <div class="resources-grid">
      {% for item in relatedCaseStudies %}
      {% if loop.index <= 3 %}
      <a class="resource-card resource-card-link" href="/proof/{{ item.slug }}/">
        <h3>{{ item.title }}</h3>
        <p>{{ item.summary }}</p>
        <span>{{ item.outcome }}</span>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if relatedDecisionGuides.length %}
<section class="section section-tight">
  <div class="container">
    <div class="pillar-header">
      <p class="hero-eyebrow">Decision Guides</p>
      <h2 class="section-title section-title-glow">City pages for price and provider-choice intent</h2>
    </div>
    <div class="link-stack">
      {% for item in relatedDecisionGuides %}
      {% if loop.index <= 6 %}
      <a class="location-card" href="{{ item.url }}">
        <strong>{{ item.label }}</strong>
        <span>{{ item.cityLabel }} decision guide for this service.</span>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
{% endif %}

<section class="section section-tight">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">At a glance</h2>
      <ul class="checklist">
        <li>Service: {{ serviceData.h1 }}</li>
        <li>Best used when: you need clearer signal before the next interview or offer cycle</li>
        <li>Primary outcome: stronger positioning, conversion, and confidence</li>
        <li>Best entry point: {{ serviceData.ctaLabel or "Book a free strategy session" }}</li>
      </ul>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Best next pages</h2>
      <div class="link-stack">
        {% if serviceData.related %}
        <a class="location-card" href="{{ serviceData.related.primaryLink }}">
          <strong>{{ serviceData.related.primaryLabel }}</strong>
          <span>{{ serviceData.related.body }}</span>
        </a>
        <a class="location-card" href="{{ serviceData.related.secondaryLink }}">
          <strong>{{ serviceData.related.secondaryLabel }}</strong>
          <span>Go deeper on the adjacent service that most often improves results with this one.</span>
        </a>
        {% endif %}
        <a class="location-card" href="/blog/interview/">
          <strong>Interview guides</strong>
          <span>Structured guides to turn stronger positioning into better live answers.</span>
        </a>
        <a class="location-card" href="/blog/salary/">
          <strong>Salary guides</strong>
          <span>Use these when you need compensation context before negotiation starts.</span>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Proof snapshot</h2>
      <ul class="checklist">
        <li>147+ professionals coached across tech, product, finance, operations, and leadership tracks</li>
        <li>4.9/5 average rating from clients who used Askia to improve interviews and offers</li>
        <li>89% of clients land offers within 60 days when they execute the plan consistently</li>
        <li>$47K average salary increase negotiated across compensation-focused engagements</li>
      </ul>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">What success usually looks like</h2>
      <ul class="checklist">
        <li>Sharper story and better recruiter response in the first two weeks</li>
        <li>Cleaner interview answers that sound more senior and more selective</li>
        <li>Stronger leverage in negotiation because the level and scope read more clearly</li>
      </ul>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container two-col-grid">
    <div class="content-panel">
      <h2 class="section-title section-title-glow">What strong signal looks like</h2>
      <ul class="checklist">
        {% for item in serviceDepth.signalPoints %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="content-panel">
      <h2 class="section-title section-title-glow">Common mistakes</h2>
      <ul class="checklist">
        {% for item in serviceDepth.commonMistakes %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% if serviceData.decisionSignals %}
<section class="section">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">What This Fixes</p>
      <h2 class="section-title section-title-glow">{{ serviceData.decisionSignals.title or "What this service should improve first" }}</h2>
      {% if serviceData.decisionSignals.subtitle %}<p class="section-subtitle">{{ serviceData.decisionSignals.subtitle }}</p>{% endif %}
    </div>
    <div class="focus-grid">
      {% for item in serviceData.decisionSignals.items %}
      <article class="focus-card">
        <span class="focus-tag">{{ item.tag }}</span>
        <h3>{{ item.title }}</h3>
        <p>{{ item.body }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# WHAT YOU GET - Simplified benefits #}
{% if serviceData.focus %}
<section class="section">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">{{ serviceData.focus.eyebrow or "What You Get" }}</p>
      <h2 class="section-title section-title-glow">{{ serviceData.focus.title }}</h2>
      {% if serviceData.focus.subtitle %}<p class="section-subtitle">{{ serviceData.focus.subtitle }}</p>{% endif %}
    </div>
    <div class="focus-grid">
      {% if serviceData.focus.items %}
        {% for item in serviceData.focus.items %}
          <article class="focus-card">
            <span class="focus-tag">{{ item.tag }}</span>
            <h3>{{ item.title }}</h3>
            <p>{{ item.body }}</p>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# HOW IT WORKS - Simple 3-step process #}
{% if serviceData.steps %}
<section class="section">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">How It Works</p>
      <h2 class="section-title section-title-glow">{{ serviceData.steps.title or "From stuck to hired in 3 steps" }}</h2>
    </div>
    <div class="category-process">
      {% if serviceData.steps.items %}
        {% for step in serviceData.steps.items %}
          <div class="process-step">
            <div class="process-number">{{ loop.index }}</div>
            <h3>{{ step.title }}</h3>
            <p>{{ step.body }}</p>
          </div>
          {% if not loop.last %}<div class="process-connector" aria-hidden="true"></div>{% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# TESTIMONIALS - Social proof near CTA #}
<section class="section section-testimonials">
  <div class="container">
    <div class="testimonials-header" style="text-align: center;">
      <p class="hero-eyebrow">Success Stories</p>
      <h2 class="section-title section-title-glow">People who made the leap</h2>
      <div class="testimonials-summary">
        <span class="testimonials-rating">★★★★★ 4.9/5</span>
        <span>from 147+ professionals</span>
      </div>
    </div>
    <div class="testimonials-carousel" data-testimonials-carousel>
      <div class="testimonials-track" data-testimonials-track>
        {% if testimonials and testimonials.items %}
          {% for item in testimonials.items %}
          <article class="testimonial-card-home" data-testimonial-card>
            <div class="testimonial-card-header">
              <img class="testimonial-avatar" src="{{ item.photo }}" alt="{{ item.name }}" loading="lazy" />
              <div>
                <strong>{{ item.name }}</strong>
                <span>{{ item.role }}{% if item.company %} · {{ item.company }}{% endif %}</span>
              </div>
            </div>
            <div class="testimonial-card-rating">★★★★★</div>
            <p class="testimonial-card-quote">"{{ item.quote | truncate(180) }}"</p>
          </article>
          {% endfor %}
          {% for item in testimonials.items %}
          <article class="testimonial-card-home" data-testimonial-card>
            <div class="testimonial-card-header">
              <img class="testimonial-avatar" src="{{ item.photo }}" alt="{{ item.name }}" loading="lazy" />
              <div>
                <strong>{{ item.name }}</strong>
                <span>{{ item.role }}{% if item.company %} · {{ item.company }}{% endif %}</span>
              </div>
            </div>
            <div class="testimonial-card-rating">★★★★★</div>
            <p class="testimonial-card-quote">"{{ item.quote | truncate(180) }}"</p>
          </article>
          {% endfor %}
        {% endif %}
      </div>
      <div class="testimonials-focus-glow" aria-hidden="true"></div>
    </div>
  </div>
</section>

{# MID-PAGE CTA - Capture convinced visitors #}
<section class="section section-mid-cta">
  <div class="container">
    <div class="mid-cta-band">
      <div class="mid-cta-content">
        <h3>Ready to accelerate your career?</h3>
        <p>Book a free strategy call and leave with a clear action plan.</p>
      </div>
      <a class="btn btn-primary btn-lg btn-glow" href="{{ serviceData.ctaLink or site.cta.link }}">{{ serviceData.ctaLabel or "Book My Free Strategy Call" }}</a>
    </div>
  </div>
</section>

{# DELIVERABLES - What you'll get #}
{% if serviceData.deliverables %}
<section class="section section-soft">
  <div class="container">
    <div class="pillar-header" style="text-align: center;">
      <p class="hero-eyebrow">Deliverables</p>
      <h2 class="section-title section-title-glow">{{ serviceData.deliverables.title }}</h2>
      {% if serviceData.deliverables.subtitle %}<p class="section-subtitle">{{ serviceData.deliverables.subtitle }}</p>{% endif %}
    </div>
    <div class="role-category-grid-enhanced">
      {% for item in serviceData.deliverables.items %}
        <div class="role-card-enhanced" style="display: block; cursor: default;">
          <div class="role-card-content">
            <strong>{{ item.title }}</strong>
            <p style="margin-top: 8px; color: var(--muted); font-size: 0.9rem;">{{ item.body }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# COACH SECTION - Build trust #}
<section class="section">
  <div class="container">
    <div class="category-coach-preview">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Askia Career Coach" class="category-coach-photo" />
      <div class="category-coach-content">
        <p class="hero-eyebrow">Your Coach</p>
        <h3 class="section-title">{{ serviceData.coach.title or "Steve gets your challenge" }}</h3>
        <p>{{ serviceData.coach.bio or "10+ years leading teams across tech companies. Hundreds of professionals coached into roles at Google, Amazon, Meta, and high-growth startups. I've sat on the other side of the table — I know exactly what makes someone stand out." }}</p>
        <div class="category-coach-stats">
          {% if serviceData.coach.stats %}
            {% for stat in serviceData.coach.stats %}
            <span><strong>{{ stat.value }}</strong> {{ stat.label }}</span>
            {% endfor %}
          {% else %}
            <span><strong>10+</strong> years experience</span>
            <span><strong>147+</strong> professionals coached</span>
            <span><strong>$47K</strong> avg. raise negotiated</span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{# WHO THIS IS FOR / NOT FOR #}
{% if serviceData.for and serviceData.notFor %}
<section class="section">
  <div class="container services-preview">
    <div class="card card-soft">
      <strong>{{ serviceData.for.title }}</strong>
      <p>{{ serviceData.for.body }}</p>
      {% if serviceData.for.items and serviceData.for.items.length %}
      <ul class="highlight-list">
        {% for item in serviceData.for.items %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    <div class="card">
      <strong>{{ serviceData.notFor.title }}</strong>
      <p>{{ serviceData.notFor.body }}</p>
      {% if serviceData.notFor.items and serviceData.notFor.items.length %}
      <ul class="highlight-list">
        {% for item in serviceData.notFor.items %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# FAQ - Handle objections #}
{% if serviceData.faq %}
<section class="section">
  <div class="container faq-stage">
    <div class="faq-header">
      <h2 class="section-title section-title-glow">{{ serviceData.faq.title }}</h2>
      {% if serviceData.faq.subtitle %}<p class="section-subtitle">{{ serviceData.faq.subtitle }}</p>{% endif %}
    </div>
    <div class="faq-grid">
      {% if serviceData.faq.items %}
        {% for item in serviceData.faq.items %}
          <details class="faq-card">
            <summary>{{ item.question }}</summary>
            <p>{{ item.answer }}</p>
          </details>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{% include "featured-markets.njk" %}

{# FINAL CTA - With testimonial and urgency #}
<section class="section section-cta-final">
  <div class="container">
    {% if serviceData.related and serviceData.related.miniTestimonial %}
    <div class="cta-testimonial-mini">
      <p>"{{ serviceData.related.miniTestimonial.quote }}"</p>
      <span>★★★★★ — {{ serviceData.related.miniTestimonial.name }}, {{ serviceData.related.miniTestimonial.role }}</span>
    </div>
    {% elif testimonials and testimonials.items %}
    {% set ctaTestimonial = testimonials.items[0] %}
    <div class="cta-testimonial-mini">
      <p>"{{ ctaTestimonial.quote | truncate(140) }}"</p>
      <span>★★★★★ — {{ ctaTestimonial.name }}, {{ ctaTestimonial.role }}</span>
    </div>
    {% else %}
    <div class="cta-testimonial-mini">
      <p>"Within 3 weeks I had 4 interviews lined up. Steve completely changed how I talk about my work."</p>
      <span>★★★★★ — Marcus T., Senior Engineer → Staff at FAANG</span>
    </div>
    {% endif %}
    <div class="cta-band">
      <div>
        <h2 class="section-title">{{ serviceData.cta.title if serviceData.cta else "Ready to accelerate your career?" }}</h2>
        <p class="section-subtitle">{{ serviceData.cta.body if serviceData.cta else "Book your free strategy session and leave with a clear action plan." }}</p>
        <p class="cta-proof">Join 147+ professionals who've accelerated their careers</p>
      </div>
      <div class="cta-action">
        <a class="btn btn-primary btn-lg btn-glow" href="{{ serviceData.cta.link if serviceData.cta else (serviceData.ctaLink or site.cta.link) }}">{{ serviceData.cta.label if serviceData.cta else "Claim My Free Strategy Session" }}</a>
        <span class="cta-urgency" data-urgency>Only 4 spots left this week</span>
        <span class="cta-guarantee">✓ Leave with a clear action plan or get a second session free</span>
      </div>
    </div>
  </div>
</section>

</div>

{% if serviceData.faq and serviceData.faq.items %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in serviceData.faq.items %}
    {
      "@type": "Question",
      "name": "{{ item.question | escape }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.answer | escape }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ (serviceData.h1 or title) | dump | safe }},
  "description": {{ (serviceData.metaDescription or serviceData.subtitle or serviceData.supporting or description) | dump | safe }},
  "url": "{{ site.url }}{{ page.url }}",
  "provider": {
    "@type": "ProfessionalService",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "serviceType": {{ (serviceData.eyebrow or "Career coaching service") | dump | safe }}
}
</script>

{% if serviceData.related %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ ((serviceData.h1 or title) + " related pages") | dump | safe }},
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ serviceData.related.primaryLabel | dump | safe }},
      "url": "{{ site.url }}{{ serviceData.related.primaryLink }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ serviceData.related.secondaryLabel | dump | safe }},
      "url": "{{ site.url }}{{ serviceData.related.secondaryLink }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Interview guides",
      "url": "{{ site.url }}/blog/interview/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Salary guides",
      "url": "{{ site.url }}/blog/salary/"
    }
  ]
}
</script>
{% endif %}
