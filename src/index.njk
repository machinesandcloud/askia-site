---
layout: layout.njk
title: Home
description: "Askia helps top talent secure high‑impact roles."
metaTitle: "Career Coaching for Ambitious Professionals | Askia"
metaDescription: "Outcome‑focused career coaching to refine your signal, interviews, and offer strategy so you land the right‑level role."
breadcrumbs:
  - name: "Home"
    url: "/"
---
<section class="hero hero-minimal">
  <div class="container hero-minimal-inner">
    <p class="hero-eyebrow animate-fade-up">{{ home.hero.eyebrow }}</p>
    <h1 class="hero-minimal-title animate-fade-up delay-1">{{ home.hero.title }}</h1>
    <p class="hero-minimal-subtitle animate-fade-up delay-2">{{ home.hero.subtitle }}</p>
    <div class="hero-minimal-cta animate-fade-up delay-3">
      <a class="btn btn-primary btn-lg" href="{{ home.hero.ctaLink }}">{{ home.hero.ctaLabel }}</a>
      <a class="btn btn-ghost" href="{{ home.hero.secondaryLink }}">{{ home.hero.secondaryLabel }}</a>
    </div>
    <div class="hero-logos animate-pop-in delay-4">
      {% for company in home.logos.companies | slice(0, 6) %}
        <img src="{{ company.logo }}" alt="{{ company.name }}" class="hero-logo-icon" style="--pop-delay: {{ loop.index0 * 0.1 }}s;" />
      {% endfor %}
    </div>
  </div>
</section>

<div class="stats-ticker">
  <div class="stats-ticker-track">
    {% for item in home.statsBanner.items %}
      <span class="stats-ticker-item">{{ item }}</span>
    {% endfor %}
    {% for item in home.statsBanner.items %}
      <span class="stats-ticker-item">{{ item }}</span>
    {% endfor %}
  </div>
</div>

<section class="section section-tight">
  <div class="container">
    <p class="logos-label">{{ home.logos.title }}</p>
    <div class="logo-carousel">
      <div class="logo-track">
        {% for company in home.logos.companies %}
          <div class="logo-item" style="--logo-accent: {{ company.accent }};">
            <img src="{{ company.logo }}" alt="{{ company.name }}" />
          </div>
        {% endfor %}
        {% for company in home.logos.companies %}
          <div class="logo-item" style="--logo-accent: {{ company.accent }};">
            <img src="{{ company.logo }}" alt="" />
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section" id="visual-demo">
  <div class="container">
    <div class="visual-demo">
      <div class="visual-demo-header animate-fade-up">
        <h2 class="section-title">{{ home.visualDemo.title }}</h2>
        <p class="section-subtitle">{{ home.visualDemo.subtitle }}</p>
      </div>
      <div class="visual-demo-grid">
        {% for metric in home.visualDemo.metrics %}
          <div class="visual-demo-card animate-fade-up" style="--delay: {{ loop.index0 * 0.15 }}s;">
            <span class="visual-demo-label">{{ metric.label }}</span>
            <div class="visual-demo-compare">
              <div class="visual-demo-before">
                <span class="visual-demo-tag">Before</span>
                <span class="visual-demo-value visual-demo-value-muted">{{ metric.before }}</span>
              </div>
              <svg class="visual-demo-arrow" viewBox="0 0 24 24" width="24" height="24">
                <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div class="visual-demo-after">
                <span class="visual-demo-tag">After</span>
                <span class="visual-demo-value visual-demo-value-accent">{{ metric.after }}</span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section section-soft" id="how-we-work">
  <div class="container">
    <h2 class="section-title section-title-center animate-fade-up">{{ home.howWeWork.title }}</h2>
    <div class="how-grid">
      {% for item in home.howWeWork.items %}
        <div class="how-card animate-fade-up" style="--delay: {{ loop.index0 * 0.1 }}s;">
          <span class="how-index">0{{ loop.index }}</span>
          <h3>{{ item.title }}</h3>
          <p>{{ item.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="comparison-header animate-fade-up">
      <h2 class="section-title">{{ home.comparison.title }}</h2>
    </div>
    <div class="comparison-table animate-fade-up delay-1">
      <div class="comparison-head">
        <div class="comparison-label"></div>
        <div class="comparison-col comparison-col-diy">{{ home.comparison.columns[0] }}</div>
        <div class="comparison-col comparison-col-askia">{{ home.comparison.columns[1] }}</div>
      </div>
      {% for row in home.comparison.rows %}
        <div class="comparison-row">
          <div class="comparison-label">{{ row.label }}</div>
          <div class="comparison-col comparison-col-diy">{{ row.diy }}</div>
          <div class="comparison-col comparison-col-askia">{{ row.askia }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft wall-of-love">
  <div class="container">
    <div class="wall-header animate-fade-up">
      <h2 class="section-title">{{ home.wallOfLove.title }}</h2>
      <p class="section-subtitle">{{ home.wallOfLove.subtitle }}</p>
    </div>
  </div>
  <div class="wall-carousel" data-wall-carousel>
    <div class="wall-track">
      {% for review in home.wallOfLove.reviews %}
        <article class="wall-card">
          <div class="wall-card-header">
            <img src="{{ review.photo }}" alt="{{ review.name }}" class="wall-avatar" />
            <div class="wall-meta">
              <strong>{{ review.name }}</strong>
              <span>{{ review.role }} · {{ review.company }}</span>
            </div>
            <span class="wall-platform wall-platform-{{ review.platform }}">
              {% if review.platform == "linkedin" %}in{% endif %}
            </span>
          </div>
          <p class="wall-quote">"{{ review.quote }}"</p>
          <span class="wall-metric">{{ review.metric }}</span>
        </article>
      {% endfor %}
      {% for review in home.wallOfLove.reviews %}
        <article class="wall-card">
          <div class="wall-card-header">
            <img src="{{ review.photo }}" alt="" class="wall-avatar" />
            <div class="wall-meta">
              <strong>{{ review.name }}</strong>
              <span>{{ review.role }} · {{ review.company }}</span>
            </div>
            <span class="wall-platform wall-platform-{{ review.platform }}">
              {% if review.platform == "linkedin" %}in{% endif %}
            </span>
          </div>
          <p class="wall-quote">"{{ review.quote }}"</p>
          <span class="wall-metric">{{ review.metric }}</span>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section-cta-mid">
  <div class="container">
    <div class="cta-mid-content animate-fade-up">
      <h3>{{ home.cta.title }}</h3>
      <p>{{ home.cta.body }}</p>
      <a class="btn btn-primary btn-lg" href="{{ home.cta.ctaLink }}">{{ home.cta.ctaLabel }}</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container coach-section">
    <div class="coach-photo animate-fade-up">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Career Coach" />
    </div>
    <div class="coach-copy animate-fade-up delay-1">
      <p class="hero-eyebrow">Your Coach</p>
      <h2 class="section-title">{{ home.coach.title }}</h2>
      <p class="section-subtitle">{{ home.coach.credential }}</p>
      <p>{{ home.coach.body }}</p>
      <ul class="highlight-list">
        {% for item in home.coach.bullets %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<section class="section">
  <div class="container cta-band animate-fade-up">
    <div>
      <h2 class="section-title">{{ home.cta.title }}</h2>
      <p class="section-subtitle">{{ home.cta.body }}</p>
    </div>
    <a class="btn btn-primary btn-lg" href="{{ home.cta.ctaLink }}">{{ home.cta.ctaLabel }}</a>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Intersection Observer for fade-up animations
  const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.animate-fade-up, .animate-pop-in').forEach(el => {
    observer.observe(el);
  });
});
</script>
