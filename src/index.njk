---
layout: layout.njk
title: Home
description: "Askia helps top talent secure high‑impact roles."
metaTitle: "Career Coaching for Ambitious Professionals | Askia"
metaDescription: "Outcome‑focused career coaching to refine your signal, interviews, and offer strategy so you land the right‑level role."
breadcrumbs:
  - name: "Home"
    url: "/"
---
<section class="hero">
  <div class="container hero-grid">
    <div>
      <p class="hero-eyebrow">{{ home.hero.eyebrow }}</p>
      <h1 class="hero-title">
        <span class="hero-title-lead">{{ home.hero.titleLead }}</span>
        <span class="hero-title-emphasis">{{ home.hero.titleEmphasis }}</span>
        <span class="hero-title-accent">{{ home.hero.titleAccent }}</span>
      </h1>
      <p class="hero-subtitle">{{ home.hero.subtitle }}</p>
      <p class="hero-supporting">{{ home.hero.supporting }}</p>
      <ul class="highlight-list">
        {% for item in home.hero.highlight %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      <div class="hero-cta">
        <a class="btn btn-primary" href="{{ home.hero.ctaLink }}">{{ home.hero.ctaLabel }}</a>
        <div class="hero-cta-meta">
          <span class="hero-urgency">{{ home.hero.ctaUrgency }}</span>
          <span class="hero-guarantee">{{ home.hero.guarantee }}</span>
        </div>
        <span class="hero-proof">{{ home.hero.proof }}</span>
      </div>
    </div>
    <div class="hero-photo">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Askia Career Coach" />
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <h3 class="section-title section-title-center">{{ home.logos.title }}</h3>
    <div class="logo-carousel">
      <div class="logo-track">
        {% for company in home.logos.companies %}
          <div class="logo-item" style="--logo-accent: {{ company.accent }};">
            <img src="{{ company.logo }}" alt="{{ company.name }}" />
          </div>
        {% endfor %}
        {% for company in home.logos.companies %}
          <div class="logo-item" style="--logo-accent: {{ company.accent }};">
            <img src="{{ company.logo }}" alt="" />
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container stats-grid">
    {% for stat in home.stats %}
      <div class="stat-card">
        <h3>{{ stat.title }}</h3>
        <p>{{ stat.body }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<section class="section">
  <div class="container pillar-wrap">
    <div class="pillar-header">
      <p class="hero-eyebrow">Askia System</p>
      <h2 class="section-title section-title-glow">{{ home.pillars.title }}</h2>
      <p class="section-subtitle">{{ home.pillars.subtitle }}</p>
    </div>
    <div class="pillar-grid">
      {% for item in home.pillars.items %}
        <div class="pillar-card">
          <div class="pillar-tag">0{{ loop.index }}</div>
          <h3 class="pillar-title">{{ item.title }}</h3>
          <p class="pillar-body">{{ item.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <div class="outcome-header">
      <h2 class="section-title section-title-accent section-title-glow">{{ home.proof.title }}</h2>
      <p class="section-subtitle">Measured wins across compensation, momentum, and leadership signal.</p>
    </div>
    <div class="outcome-grid">
      {% for item in home.proof.items %}
        <div class="outcome-card">
          <span class="outcome-number">{{ item.title }}</span>
          <p>{{ item.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container success-wrap">
    <div class="success-copy">
      <p class="hero-eyebrow">Success Stories</p>
      <h2 class="section-title">{{ home.success.title }}</h2>
      <p class="section-subtitle">{{ home.success.subtitle }}</p>
      <p>{{ home.success.body }}</p>
    </div>
    <div class="success-carousel" data-success-carousel>
      <div class="success-viewport">
        {% for item in home.success.items %}
          <div class="success-slide{% if loop.first %} is-active{% endif %}">
            <img src="{{ item.image }}" alt="{{ item.name }} - {{ item.role }}" />
            <div class="success-caption">
              <strong>{{ item.name }}</strong>
              <span>{{ item.role }} · {{ item.company }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="success-dots">
        {% for item in home.success.items %}
          <span{% if loop.first %} class="is-active"{% endif %}></span>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section-cta-mid">
  <div class="container">
    <div class="cta-mid-content">
      <h3>Ready to stop being overlooked?</h3>
      <a class="btn btn-primary" href="{{ home.hero.ctaLink }}">{{ home.hero.ctaLabel }}</a>
      <span class="hero-urgency">{{ home.hero.ctaUrgency }}</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container flow-section">
    <div class="flow-header">
      <p class="hero-eyebrow">How It Works</p>
      <h2 class="section-title">{{ home.program.title }}</h2>
    </div>
    <div class="flow-list">
      {% for step in home.program.steps %}
        <div class="flow-item">
          <span class="flow-index">0{{ loop.index }}</span>
          <div>
            <h4>{{ step.title }}</h4>
            <p>{{ step.body }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container coach-section">
    <div class="coach-photo">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Career Coach" />
    </div>
    <div class="coach-copy">
      <p class="hero-eyebrow">Your Coach</p>
      <h2 class="section-title">{{ home.coach.title }}</h2>
      <p class="section-subtitle">{{ home.coach.credential }}</p>
      <p>{{ home.coach.body }}</p>
      <ul class="highlight-list">
        {% for item in home.coach.bullets %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<section class="section">
  <div class="container cta-band">
    <div>
      <h2 class="section-title">{{ home.cta.title }}</h2>
      <p class="section-subtitle">{{ home.cta.body }}</p>
      <div class="cta-band-meta">
        <span class="hero-urgency">{{ home.cta.urgency }}</span>
        <span class="hero-guarantee">{{ home.cta.guarantee }}</span>
      </div>
    </div>
    <a class="btn btn-primary" href="{{ home.cta.ctaLink }}">{{ home.cta.ctaLabel }}</a>
  </div>
</section>
