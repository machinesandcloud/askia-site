---
layout: layout.njk
title: Home
description: "Askia helps top talent secure high‑impact roles."
metaTitle: "Career Coaching for Ambitious Professionals | Askia"
metaDescription: "Outcome‑focused career coaching to refine your signal, interviews, and offer strategy so you land the right‑level role."
breadcrumbs:
  - name: "Home"
    url: "/"
---
<section class="hero hero-v2">
  <div class="container hero-grid">
    <div class="hero-content">
      <p class="hero-eyebrow">{{ home.hero.eyebrow }}</p>
      <h1 class="hero-headline">Land Your Dream Role in <span class="hero-highlight">90 Days</span></h1>
      <p class="hero-subheadline">{{ home.hero.subheadline }}</p>

      {% if home.hero.benefits %}
      <ul class="hero-benefits">
        {% for benefit in home.hero.benefits %}
          <li>{{ benefit }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      <div class="hero-cta-block">
        <a class="btn btn-primary btn-lg btn-glow" href="{{ home.hero.ctaLink }}">{{ home.hero.ctaLabel }}</a>
        <span class="hero-microcopy">{{ home.hero.ctaMicrocopy }}</span>
        <span class="hero-urgency" data-urgency>{{ home.hero.ctaUrgency }}</span>
      </div>

      <div class="hero-proof-simple">
        <span class="hero-trust-rating">{{ home.hero.trustLabel }}</span>
      </div>
    </div>
    <div class="hero-visual-v2">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Askia Career Coach" class="hero-photo" />
      {% if home.hero.heroStats %}
      <div class="hero-stats-sidebar">
        {% for stat in home.hero.heroStats %}
          <div class="hero-stat-item">
            <strong>{{ stat.value }}</strong>
            <span>{{ stat.label }}</span>
          </div>
        {% endfor %}
      </div>
      {% endif %}
      <div class="hero-guarantee-badge">
        <span>✓</span>
        {{ home.hero.guarantee }}
      </div>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <h3 class="section-title section-title-center">{{ home.logos.title }}</h3>
    <div class="logo-carousel">
      <div class="logo-track">
        {% for company in home.logos.companies %}
          <div class="logo-item" style="--logo-accent: {{ company.accent }};">
            <img src="{{ company.logo }}" alt="{{ company.name }}" />
          </div>
        {% endfor %}
        {% for company in home.logos.companies %}
          <div class="logo-item" style="--logo-accent: {{ company.accent }};">
            <img src="{{ company.logo }}" alt="" />
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container pillar-wrap">
    <div class="pillar-header">
      <p class="hero-eyebrow">Askia System</p>
      <h2 class="section-title section-title-glow">{{ home.pillars.title }}</h2>
      <p class="section-subtitle">{{ home.pillars.subtitle }}</p>
      <div class="application-visual" aria-hidden="true">
        <div class="application-track">
          <div class="application-phase phase-1">
          <div class="application-card">
            <span class="application-title">Application #012</span>
            <span class="application-role">Product Manager</span>
            <span class="application-name">Jordan R.</span>
            <span class="application-status denied">Denied</span>
          </div>
          <div class="application-card">
            <span class="application-title">Application #013</span>
            <span class="application-role">Senior Analyst</span>
            <span class="application-name">Priya S.</span>
            <span class="application-status denied">No response</span>
          </div>
          <div class="application-card">
            <span class="application-title">Application #014</span>
            <span class="application-role">Engineering Lead</span>
            <span class="application-name">Marcus K.</span>
            <span class="application-status denied">Rejected</span>
          </div>
            <div class="application-stamps">
              <span class="stamp stamp-1">Rejected</span>
              <span class="stamp stamp-2">Denied</span>
              <span class="stamp stamp-3">No response</span>
            </div>
          </div>
          <div class="application-phase phase-2">
          <div class="application-card">
            <span class="application-title">Resume</span>
            <span class="application-role">Signal + story rebuilt</span>
            <span class="application-name">Alicia M.</span>
            <span class="application-status progress">In progress</span>
          </div>
          <div class="application-card">
            <span class="application-title">Job Search Strategy</span>
            <span class="application-role">Targeted outreach + pipeline</span>
            <span class="application-name">Devon T.</span>
            <span class="application-status progress">Focused</span>
          </div>
          <div class="application-card">
            <span class="application-title">Interview Prep</span>
            <span class="application-role">Stories, hooks, confidence</span>
            <span class="application-name">Sofia N.</span>
            <span class="application-status progress">Ready</span>
          </div>
            <div class="application-stamps">
              <span class="stamp stamp-1 stamp-progress">Rebuilt</span>
              <span class="stamp stamp-2 stamp-progress">Strategic</span>
              <span class="stamp stamp-3 stamp-progress">Prepared</span>
            </div>
          </div>
          <div class="application-phase phase-3">
          <div class="application-card">
            <span class="application-title">First interview</span>
            <span class="application-role">Calendars fill fast</span>
            <span class="application-name">Isaac W.</span>
            <span class="application-status success">Booked</span>
          </div>
          <div class="application-card">
            <span class="application-title">Offer landed</span>
            <span class="application-role">Decision on your terms</span>
            <span class="application-name">Renee L.</span>
            <span class="application-status success">Offer</span>
          </div>
          <div class="application-card">
            <span class="application-title">Salary increase</span>
            <span class="application-role">Negotiate from strength</span>
            <span class="application-name">Omar P.</span>
            <span class="application-status success">+$47K</span>
          </div>
            <div class="application-stamps">
              <span class="stamp stamp-1 stamp-success">Interviewed</span>
              <span class="stamp stamp-2 stamp-success">Hired</span>
              <span class="stamp stamp-3 stamp-success">Raised</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="pillar-grid">
      {% for item in home.pillars.items %}
        <div class="pillar-card">
          <div class="pillar-tag">0{{ loop.index }}</div>
          <h3 class="pillar-title">{{ item.title }}</h3>
          <p class="pillar-body">{{ item.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <div class="outcome-header">
      <h2 class="section-title section-title-accent section-title-glow">{{ home.proof.title }}</h2>
      <p class="section-subtitle">Measured wins across compensation, momentum, and leadership signal.</p>
    </div>
    <div class="outcome-grid">
      {% for item in home.proof.items %}
        <div class="outcome-card">
          <span class="outcome-number">{{ item.title }}</span>
          <p>{{ item.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container assessment">
    <div class="assessment-header">
      <p class="hero-eyebrow">Career Readiness Index™</p>
      <h2 class="section-title">For Ambitious Professionals & Leaders</h2>
      <p class="section-subtitle">“This assessment measures how ready your career is for the role you actually want — not the one you’re settling for.”</p>
      <p class="assessment-meta">⏱ 3–4 minutes · No email required until results</p>
    </div>
    <div class="assessment-form" data-assessment>
      <div class="assessment-progress">
        <span data-assessment-step>1</span> / <span data-assessment-total>10</span>
        <div class="assessment-bar"><div data-assessment-bar></div></div>
      </div>
      <div class="assessment-panel">
        <p class="assessment-section" data-assessment-section></p>
        <h3 class="assessment-question-title" data-assessment-question></h3>
        <p class="assessment-question-sub" data-assessment-sub></p>
        <div class="assessment-options" data-assessment-options></div>
        <p class="assessment-note" data-assessment-note></p>
      </div>
      <div class="assessment-actions">
        <button type="button" class="btn btn-ghost" data-assessment-prev>Back</button>
        <button type="button" class="btn btn-primary" data-assessment-next>Next</button>
        <span class="assessment-hint">Maximum score: 48 · Minimum score: 1</span>
      </div>
      <p class="assessment-footnote">“The Career Readiness Index™ is based on real hiring patterns across senior, leadership, and cross‑functional roles — not generic career advice.”</p>
      <div class="assessment-overlay" data-assessment-overlay hidden>
        <div class="assessment-result" data-assessment-result>
          <button class="assessment-close" type="button" data-assessment-close>Close</button>
          <p class="assessment-score" data-assessment-score></p>
          <h3 data-assessment-title></h3>
          <p data-assessment-message></p>
          <ul data-assessment-recommendation></ul>
          <div class="assessment-email">
            <p class="assessment-email-title">Want your score + action plan emailed?</p>
            <form name="career-readiness" method="POST" action="/" data-netlify="true" class="assessment-email-form" data-assessment-form>
              <input type="hidden" name="form-name" value="career-readiness" />
              <input type="hidden" name="score" value="" data-assessment-score-field />
              <input type="hidden" name="bucket" value="" data-assessment-bucket-field />
              <input type="hidden" name="source" value="" data-assessment-source-field />
              <label>
                <span>Full name</span>
                <input type="text" name="name" placeholder="Your name" />
              </label>
              <label>
                <span>Email</span>
                <input type="email" name="email" placeholder="you@company.com" required />
              </label>
              <label>
                <span>Target role</span>
                <input type="text" name="role" placeholder="Senior SWE, EM, DevOps, PM..." />
              </label>
              <button class="btn btn-primary" type="submit">Email my results</button>
              <p class="assessment-submit-message" data-assessment-submit-message></p>
            </form>
          </div>
          <a class="btn btn-ghost" href="{{ site.cta.link }}" data-assessment-book>Book a Strategy Call</a>
          <p class="assessment-cta" data-assessment-cta></p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-testimonials">
  <div class="container">
    <div class="testimonials-header">
      <p class="hero-eyebrow">Client Results</p>
      <h2 class="section-title section-title-glow">{{ home.success.title }}</h2>
      <p class="section-subtitle">{{ home.success.subtitle }}</p>
      <div class="testimonials-summary">
        <span class="testimonials-rating">★★★★★ 4.9/5</span>
        <span>from 147+ professionals</span>
      </div>
    </div>
    <div class="testimonials-carousel" data-testimonials-carousel>
      <div class="testimonials-track" data-testimonials-track>
        {% for item in testimonials.items %}
        <article class="testimonial-card-home" data-testimonial-card>
          <div class="testimonial-card-header">
            <img class="testimonial-avatar" src="{{ item.photo }}" alt="{{ item.name }}" />
            <div>
              <strong>{{ item.name }}</strong>
              <span>{{ item.role }}{% if item.company %} · {{ item.company }}{% endif %}</span>
            </div>
          </div>
          <div class="testimonial-card-rating">★★★★★</div>
          <p class="testimonial-card-quote">"{{ item.quote | truncate(180) }}"</p>
        </article>
        {% endfor %}
        {% for item in testimonials.items %}
        <article class="testimonial-card-home" data-testimonial-card>
          <div class="testimonial-card-header">
            <img class="testimonial-avatar" src="{{ item.photo }}" alt="{{ item.name }}" />
            <div>
              <strong>{{ item.name }}</strong>
              <span>{{ item.role }}{% if item.company %} · {{ item.company }}{% endif %}</span>
            </div>
          </div>
          <div class="testimonial-card-rating">★★★★★</div>
          <p class="testimonial-card-quote">"{{ item.quote | truncate(180) }}"</p>
        </article>
        {% endfor %}
      </div>
      <div class="testimonials-focus-glow" aria-hidden="true"></div>
    </div>
    <div class="testimonials-cta">
      <a class="btn btn-ghost" href="/testimonials/">Read all testimonials</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container services-preview">
    <div class="services-copy">
      <p class="hero-eyebrow">Services</p>
      <h2 class="section-title section-title-glow">Choose the support level that fits your goals</h2>
      <p class="section-subtitle">From focused strategy to full transformation, each pathway is built to get you hired faster.</p>
      <a class="btn btn-ghost" href="/services/">See all services</a>
    </div>
    <div class="service-stack">
      {% for item in services.services %}
        <div class="service-tile">
          <div class="service-header">
            <h3>{{ item.title }}</h3>
            <span class="service-tag">Premium</span>
          </div>
          <p>{{ item.body }}</p>
          <ul>
            {% for bullet in item.bullets %}
              <li>{{ bullet }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container coach-section">
    <div class="coach-photo">
      <img src="/assets/steve-headshot.jpg" alt="Steve, Askia Career Coach" />
    </div>
    <div class="coach-copy">
      <p class="hero-eyebrow">Founder, Head Coach</p>
      <h3 class="section-title">{{ home.coach.title }}</h3>
      <p class="section-subtitle">{{ home.coach.credential }}</p>
      <p>{{ home.coach.body }}</p>
      <ul class="highlight-list">
        {% for item in home.coach.bullets %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      <a class="btn btn-primary" href="{{ site.cta.link }}">Book a Call with Steve</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container timeline-track">
    <h2 class="section-title">{{ home.timeline.title }}</h2>
    <div class="timeline-rail">
      {% for step in home.timeline.steps %}
        <div class="timeline-node">
          <strong>{{ step.title }}</strong>
          <p>{{ step.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>


<section class="section">
  <div class="container cta-band">
    <div>
      <h2 class="section-title">{{ home.cta.title }}</h2>
      <p class="section-subtitle">{{ home.cta.body }}</p>
      {% if home.cta.proofSnippet %}<p class="cta-proof">{{ home.cta.proofSnippet }}</p>{% endif %}
    </div>
    <div class="cta-action">
      <a class="btn btn-primary" href="{{ home.cta.ctaLink }}">{{ home.cta.ctaLabel }}</a>
      {% if home.cta.urgency %}<span class="cta-urgency">{{ home.cta.urgency }}</span>{% endif %}
      {% if home.cta.guarantee %}<span class="cta-guarantee">✓ {{ home.cta.guarantee }}</span>{% endif %}
    </div>
  </div>
</section>
