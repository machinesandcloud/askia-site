---
layout: layout.njk
title: Career Resources
metaTitle: "Career Resources for Tech, Product & Finance Professionals | Askia"
metaDescription: "100+ role-specific guides covering resume writing, LinkedIn, interview prep, salary negotiation, and more — built for senior roles in SWE, DevOps, Data, Product, EM, and Finance."
breadcrumbs:
  - name: "Home"
    url: "/"
  - name: "Resources"
    url: "/resources/"
---

<div class="rh2-page">

{# ─── HERO ────────────────────────────────────────────── #}
<section class="rh2-hero">
  <div class="container rh2-hero-inner">
    <p class="rh2-kicker">Career Intelligence</p>
    <h1 class="rh2-hero-title">The playbook for<br>landing the role.</h1>
    <p class="rh2-hero-sub">100+ guides written for senior professionals in tech, product, and finance. Each guide is specific to your role, not generic career advice.</p>
    <div class="rh2-hero-cta">
      <a class="btn btn-primary" href="{{ site.cta.link }}">{{ site.cta.label }}</a>
      <a class="btn btn-ghost" href="/career-readiness-index/">Take the career assessment</a>
    </div>
    <div class="rh2-hero-stats">
      <div class="rh2-hs"><span>{{ roleSubPages | length }}</span><p>role-specific guides</p></div>
      <div class="rh2-hs"><span>{{ roleTracks | length }}</span><p>grouped career tracks</p></div>
      <div class="rh2-hs"><span>29</span><p>target roles covered</p></div>
      <div class="rh2-hs"><span>$47K+</span><p>avg comp increase</p></div>
      <div class="rh2-hs"><span>89%</span><p>of clients land offers in 60 days</p></div>
    </div>
  </div>
</section>

{# ─── ROLE TRACK GROUPS ───────────────────────────────── #}
<section class="rh2-tracks">
  <div class="container">
    <div class="rh2-tracks-header">
      <h2 class="rh2-section-title">Pick your track</h2>
      <p class="rh2-section-sub">Browse by category first, then go straight into the role track that matches the work you actually want. Every track links to five role-specific guides.</p>
    </div>
    <div class="rh2-group-list">
      {% for group in roleTracks %}
      <section class="rh2-group">
        <div class="rh2-group-head">
          <div>
            <p class="rh2-group-kicker">{{ group.name }}</p>
            <h3 class="rh2-group-title">{{ group.name }}</h3>
          </div>
          <p class="rh2-group-copy">{{ group.description }}</p>
        </div>
        <div class="rh2-group-grid">
          {% for role in group.roles %}
          <a class="rh2-track-card" href="/resources/{{ role.role }}/" style="--tc: {{ role.color }};">
            <div class="rh2-track-top">
              <span class="rh2-track-emoji">{{ role.emoji }}</span>
              <span class="rh2-track-tag">{{ role.tag }}</span>
            </div>
            <h3 class="rh2-track-name">{{ role.name }}</h3>
            <p class="rh2-track-desc">{{ role.desc }}</p>
            <div class="rh2-track-topics">
              {% for guide in roleSubPages %}
                {% if guide.role == role.role %}
                <span>{{ guide.topicName }}</span>
                {% endif %}
              {% endfor %}
            </div>
            <div class="rh2-track-footer">
              <span class="rh2-track-count">5 guides</span>
              <span class="rh2-track-cta">Explore track →</span>
            </div>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endfor %}
    </div>
  </div>
</section>

{# ─── TOPIC GUIDES (original /resources/[topic]/ pages) ── #}
<section class="rh2-topics-section">
  <div class="container">
    <div class="rh2-topics-header">
      <h2 class="rh2-section-title">General guides</h2>
      <p class="rh2-section-sub">Topic-level deep dives that apply across all roles.</p>
    </div>
    <div class="rh2-topics-list">
      <a class="rh2-topic-item" href="/resources/ats/">
        <span class="rh2-topic-num">01</span>
        <div class="rh2-topic-content">
          <h3>ATS Optimization</h3>
          <p>How to format your resume so it actually gets read by humans.</p>
        </div>
        <span class="rh2-topic-arrow">→</span>
      </a>
      <a class="rh2-topic-item" href="/resources/resume/">
        <span class="rh2-topic-num">02</span>
        <div class="rh2-topic-content">
          <h3>Resume Writing</h3>
          <p>Impact-first bullets that get senior-level callbacks.</p>
        </div>
        <span class="rh2-topic-arrow">→</span>
      </a>
      <a class="rh2-topic-item" href="/resources/linkedin/">
        <span class="rh2-topic-num">03</span>
        <div class="rh2-topic-content">
          <h3>LinkedIn Optimization</h3>
          <p>How to make recruiters reach out to you instead of the other way around.</p>
        </div>
        <span class="rh2-topic-arrow">→</span>
      </a>
      <a class="rh2-topic-item" href="/resources/interview-prep/">
        <span class="rh2-topic-num">04</span>
        <div class="rh2-topic-content">
          <h3>Interview Preparation</h3>
          <p>Walk into interviews knowing exactly what to say.</p>
        </div>
        <span class="rh2-topic-arrow">→</span>
      </a>
      <a class="rh2-topic-item" href="/resources/salary-negotiation/">
        <span class="rh2-topic-num">05</span>
        <div class="rh2-topic-content">
          <h3>Salary Negotiation</h3>
          <p>Negotiate offers without risking the deal. 85% of offers have room to move.</p>
        </div>
        <span class="rh2-topic-arrow">→</span>
      </a>
      <a class="rh2-topic-item" href="/resources/cover-letters/">
        <span class="rh2-topic-num">06</span>
        <div class="rh2-topic-content">
          <h3>Cover Letters</h3>
          <p>When you need one and how to write it in under 150 words.</p>
        </div>
        <span class="rh2-topic-arrow">→</span>
      </a>
    </div>
  </div>
</section>

{# ─── BOTTOM CTA ──────────────────────────────────────── #}
<section class="rh2-cta">
  <div class="container rh2-cta-inner">
    <h2>Want a tailored plan, not a guide?</h2>
    <p>Book a strategy call. We'll map the fastest path to your target role based on where you actually are right now.</p>
    <a class="btn btn-primary" href="{{ site.cta.link }}">{{ site.cta.label }}</a>
  </div>
</section>

</div>

<script type="application/ld+json">
{"@context":"https://schema.org","@type":"CollectionPage","name":"Askia Career Resources","description":"100+ role-specific career guides for Software Engineering, DevOps/SRE, Data, Product Management, Engineering Management, and Finance.","url":"{{ site.url }}/resources/"}
</script>
