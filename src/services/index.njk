---
layout: layout.njk
title: Services
description: "Askia coaching services to land high‑impact roles."
metaTitle: "Coaching Services That Move Your Next Role | Askia"
metaDescription: "Outcome‑focused coaching services across resume, LinkedIn, interviews, and offer strategy."
breadcrumbs:
  - name: "Home"
    url: "/"
  - name: "Services"
    url: "/services/"
---
<div class="resource-theme-page">
<section class="services-hero-new resource-theme-hero">
  <div class="container services-hero-grid">
    <div class="services-hero-copy">
      <p class="hero-eyebrow">Services</p>
      <h1 class="services-hero-title">{{ services.hero.title }}</h1>
      <p class="services-hero-subtitle">{{ services.hero.subtitle }}</p>
      <p class="services-hero-supporting">Pick a focused upgrade or build a full system. We’ll help you choose the fastest path.</p>
      <div class="hero-cta">
        <a class="btn btn-primary btn-cta-experiment" href="{{ services.hero.ctaLink }}">{{ services.hero.ctaLabel }}</a>
        <a class="btn btn-ghost" href="/resources/">View resources</a>
      </div>
      <p class="hero-microcopy">15 minutes. No sales pitch. Leave with a clear action plan.</p>
      <div class="services-hero-trust">
        <span class="services-hero-rating">★★★★★ 4.9/5 from 147+ professionals</span>
        <div class="services-hero-logos">
          {% for company in home.logos.companies | slice(0, 5) %}
            <img src="{{ company.logo }}" alt="{{ company.name }}" />
          {% endfor %}
        </div>
      </div>
      <div class="services-hero-metrics">
        <div><strong>7–14 days</strong><span>Typical delivery</span></div>
        <div><strong>2–6 weeks</strong><span>Coaching timelines</span></div>
        <div><strong>Signal-first</strong><span>Positioning system</span></div>
      </div>
    </div>
    <div class="services-hero-panel">
      <div class="services-hero-card">
        <strong>What clients choose first</strong>
        <p>Most start with a brand refresh, then add coaching as interviews begin.</p>
        <div class="services-hero-chips">
          <span>Resume upgrade</span>
          <span>LinkedIn signal</span>
          <span>Interview practice</span>
        </div>
      </div>
      <div class="services-hero-card accent">
        <strong>Outcomes you can feel</strong>
        <p>Clear positioning, interview momentum, and offer leverage.</p>
      </div>
    </div>
  </div>
</section>

<section class="section services-pillars">
  <div class="container">
    <div class="pillar-header">
      <p class="hero-eyebrow">Service pillars</p>
      <h2 class="section-title section-title-glow">Build signal at every stage</h2>
      <p class="section-subtitle">Each service is designed to move you toward interviews and offers.</p>
    </div>
    <div class="services-pillar-grid">
      <div class="services-pillar">
        <strong>Signal</strong>
        <p>Positioning, resume, LinkedIn, and story architecture.</p>
      </div>
      <div class="services-pillar">
        <strong>Momentum</strong>
        <p>Role targeting, outreach guidance, and interview preparation.</p>
      </div>
      <div class="services-pillar">
        <strong>Conversion</strong>
        <p>Offer strategy, negotiation, and decision support.</p>
      </div>
    </div>
  </div>
</section>

<section class="section services-grid">
  <div class="container">
    <div class="service-carousel">
      <div class="service-carousel-top">
        <div class="pillar-header">
          <p class="hero-eyebrow">Core services</p>
          <h2 class="section-title section-title-glow">Choose the path that fits your stage</h2>
          <p class="section-subtitle">Start lean or go all‑in with a full brand rebuild.</p>
        </div>
        <div class="carousel-controls">
          <button class="carousel-btn" type="button" data-carousel-prev>Prev</button>
          <button class="carousel-btn" type="button" data-carousel-next>Next</button>
        </div>
      </div>
      <div class="carousel-viewport" data-service-carousel>
        <div class="carousel-track" data-service-track>
          {% for tier in services.tiers %}
            <article class="carousel-card services-card{% if tier.tag == 'Most Popular' %} is-featured{% endif %}">
              <span class="services-tag">{{ tier.tag }}</span>
              <span class="card-graphic" aria-hidden="true"></span>
              <h3>{{ tier.title }}</h3>
              <p class="services-price">{{ tier.price }}</p>
              <p>{{ tier.body }}</p>
              <ul>
                {% for bullet in tier.bullets %}
                  {% if bullet.label %}
                    <li>
                      <span>{{ bullet.label }}</span>
                      {% if bullet.detailTitle or bullet.detailBody %}
                        <button
                          type="button"
                          class="pricing-detail"
                          data-pricing-detail
                          data-pricing-title="{{ bullet.detailTitle | default(bullet.label) }}"
                          data-pricing-body="{{ bullet.detailBody | default('') }}"
                          data-pricing-points="{% if bullet.detailPoints %}{{ bullet.detailPoints | join('||') }}{% endif %}"
                          aria-label="Learn more about {{ bullet.label }}"
                        >
                          +
                        </button>
                      {% endif %}
                    </li>
                  {% else %}
                    <li>{{ bullet }}</li>
                  {% endif %}
                {% endfor %}
              </ul>
              <div class="services-meta">
                <span>{{ tier.ideal }}</span>
                <span>{{ tier.turnaround }}</span>
              </div>
              <a class="btn btn-primary btn-buy" href="{{ tier.buyLink }}">Buy now</a>
            </article>
          {% endfor %}
        </div>
      </div>
      <div class="carousel-dots" data-carousel-dots></div>
    </div>
  </div>
</section>

<section class="section services-core">
  <div class="container">
    <div class="services-core-head">
      <div>
        <p class="hero-eyebrow">Core Services</p>
        <h2 class="section-title section-title-glow">Choose a focused upgrade</h2>
        <p class="section-subtitle">Clear, high‑impact services that stack together when you want more support.</p>
        <div class="services-core-proof">
          <span>★★★★★ 4.9/5 from 147+ professionals</span>
          <span>No credit card. No commitment.</span>
        </div>
      </div>
      <a class="btn btn-primary btn-cta-experiment" href="{{ services.cta.ctaLink }}">Get a recommendation</a>
    </div>
    <div class="services-core-grid">
      {% for item in services.alaCarte.items %}
        <a class="services-core-card" href="{{ item.pageLink or item.buyLink }}">
          <div class="services-core-card-top">
            <h3>{{ item.title }}</h3>
            {% if item.price %}<span class="services-core-price">{{ item.price }}</span>{% endif %}
          </div>
          <p>{{ item.body }}</p>
        </a>
      {% endfor %}
    </div>
    <div class="services-core-orbit" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
  </div>
</section>

<section class="section services-outcomes">
  <div class="container">
    <div class="services-outcomes-head">
      <p class="hero-eyebrow">What You Get</p>
      <h2 class="section-title section-title-glow">Signal, momentum, leverage</h2>
      <p class="section-subtitle">A clear system that moves you from scattered effort to the right offer.</p>
    </div>
    <div class="services-outcomes-grid">
      <div class="services-outcome-card">
        <span>01</span>
        <h3>Signal</h3>
        <p>Role‑aligned narrative, resume, and LinkedIn that read at the right level.</p>
      </div>
      <div class="services-outcome-card">
        <span>02</span>
        <h3>Momentum</h3>
        <p>Search strategy and interview prep that accelerate results.</p>
      </div>
      <div class="services-outcome-card">
        <span>03</span>
        <h3>Leverage</h3>
        <p>Offer strategy and negotiation guidance aligned to comp bands.</p>
      </div>
      <div class="services-outcome-card highlight">
        <span>04</span>
        <h3>Clarity</h3>
        <p>A scoped plan that matches your role, timeline, and target level.</p>
      </div>
    </div>
    <div class="services-outcomes-rail" aria-hidden="true">
      <span>Position</span>
      <span>Execute</span>
      <span>Close</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container faq-stage">
    <div class="faq-header">
      <h2 class="section-title section-title-glow">{{ services.faq.title }}</h2>
      <p class="section-subtitle">Short, clear answers to the questions we hear most before someone books.</p>
    </div>
    <div class="faq-grid">
      {% for item in services.faq.items %}
        <details class="faq-card">
          <summary>{{ item.question }}</summary>
          <p>{{ item.answer }}</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
    <div class="container cta-band">
    <div>
      <h2 class="section-title">{{ services.cta.title }}</h2>
      <p class="section-subtitle">{{ services.cta.body }}</p>
      <div class="cta-proof">
        <span>★★★★★ 4.9/5 from 147+ professionals</span>
        <span>“Clear plan, better interviews, higher offer.”</span>
      </div>
    </div>
    <a class="btn btn-primary btn-cta-experiment" href="{{ services.cta.ctaLink }}">{{ services.cta.ctaLabel }}</a>
  </div>
</section>

<div class="pricing-overlay" data-pricing-overlay hidden>
  <div class="pricing-modal" role="dialog" aria-modal="true" aria-labelledby="pricing-modal-title">
    <button class="pricing-close" type="button" data-pricing-close aria-label="Close details">✕</button>
    <h3 id="pricing-modal-title" data-pricing-title></h3>
    <p data-pricing-body></p>
    <ul data-pricing-points></ul>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.querySelector("[data-pricing-overlay]");
    if (!overlay) return;

    const titleEl = overlay.querySelector("[data-pricing-title]");
    const bodyEl = overlay.querySelector("[data-pricing-body]");
    const pointsEl = overlay.querySelector("[data-pricing-points]");
    const closeBtn = overlay.querySelector("[data-pricing-close]");
    const detailButtons = document.querySelectorAll("[data-pricing-detail]");

    const openModal = (button) => {
      titleEl.textContent = button.dataset.pricingTitle || "Details";
      bodyEl.textContent = button.dataset.pricingBody || "";
      const points = (button.dataset.pricingPoints || "").split("||").filter(Boolean);
      pointsEl.innerHTML = points.map((point) => `<li>${point}</li>`).join("");
      overlay.hidden = false;
      document.body.classList.add("pricing-focus");
    };

    const closeModal = () => {
      overlay.hidden = true;
      document.body.classList.remove("pricing-focus");
      titleEl.textContent = "";
      bodyEl.textContent = "";
      pointsEl.innerHTML = "";
    };

    detailButtons.forEach((button) => {
      button.addEventListener("click", () => openModal(button));
    });

    closeBtn.addEventListener("click", closeModal);
    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) closeModal();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !overlay.hidden) closeModal();
    });
  });
</script>

</div>
